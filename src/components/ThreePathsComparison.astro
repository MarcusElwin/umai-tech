---
export interface Props {
  paths: Array<{
    id: string;
    title: string;
    subtitle: string;
    description: string;
    strengths: string[];
    tradeoffs: string[];
    examples: string[];
    icon: string;
    color: 'purple' | 'blue' | 'green';
    highlighted?: boolean;
  }>;
}

const { paths } = Astro.props;

function getColorStyle(color: string) {
  const colors = {
    purple: {
      bg: 'bg-gradient-to-br from-purple-50 to-purple-100 dark:from-purple-950/40 dark:to-purple-900/30',
      border: 'border-purple-300 dark:border-purple-700',
      ring: 'ring-purple-400 dark:ring-purple-600',
      iconBg: 'bg-purple-600',
      badge: 'bg-purple-600 text-white',
      dot: 'bg-purple-500',
      text: 'text-purple-600 dark:text-purple-400',
      headerBg: 'bg-purple-600 dark:bg-purple-700'
    },
    blue: {
      bg: 'bg-gradient-to-br from-blue-50 to-blue-100 dark:from-blue-950/40 dark:to-blue-900/30',
      border: 'border-blue-300 dark:border-blue-700',
      ring: 'ring-blue-400 dark:ring-blue-600',
      iconBg: 'bg-blue-600',
      badge: 'bg-blue-600 text-white',
      dot: 'bg-blue-500',
      text: 'text-blue-600 dark:text-blue-400',
      headerBg: 'bg-blue-600 dark:bg-blue-700'
    },
    green: {
      bg: 'bg-gradient-to-br from-green-50 to-green-100 dark:from-green-950/40 dark:to-green-900/30',
      border: 'border-green-300 dark:border-green-700',
      ring: 'ring-green-400 dark:ring-green-600',
      iconBg: 'bg-green-600',
      badge: 'bg-green-600 text-white',
      dot: 'bg-green-500',
      text: 'text-green-600 dark:text-green-400',
      headerBg: 'bg-green-600 dark:bg-green-700'
    }
  };
  return colors[color as keyof typeof colors] || colors['blue'];
}
---

<div class="three-paths-comparison my-12">
  <!-- Header -->
  <div class="bg-gradient-to-r from-umai-gray-50 to-white dark:from-umai-gray-800 dark:to-umai-gray-700 rounded-xl border border-umai-gray-200 dark:border-umai-gray-600 p-6 mb-6">
    <div class="flex items-start justify-between gap-4">
      <div class="flex-1">
        <h4 class="text-xl font-bold text-gray-900 dark:text-white mb-2">The Three Engineering Archetypes</h4>
        <p class="text-gray-600 dark:text-gray-400 mb-4">
          How AI is reshaping the traditional career paths in software engineering
        </p>

        <!-- Collapse Toggle -->
        <button
          id="paths-toggle"
          class="flex items-center space-x-2 text-sm text-umai-accent hover:text-umai-accent/80 transition-colors focus:outline-none"
          aria-expanded="false"
          aria-controls="paths-content"
        >
          <span id="paths-toggle-text">Show Comparison</span>
          <svg id="paths-toggle-icon" class="w-4 h-4 transition-transform duration-200 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Collapsible Content -->
  <div id="paths-content" class="hidden transition-all duration-300 ease-in-out overflow-hidden">
    <div class="grid md:grid-cols-3 gap-6 pt-2">
      {paths.map((path: any) => {
        const colorStyle = getColorStyle(path.color);

        return (
          <div class={`path-card ${path.highlighted ? 'ring-4 ' + colorStyle.ring : ''} ${colorStyle.bg} ${colorStyle.border} border rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 relative overflow-hidden`}>

            {/* Highlighted Badge */}
            {path.highlighted && (
              <div class={`absolute top-0 left-0 right-0 ${colorStyle.headerBg} text-white text-xs font-bold px-4 py-1.5 text-center`}>
                The Third Path
              </div>
            )}

            <div class={`p-6 ${path.highlighted ? 'pt-10' : ''}`}>
              {/* Icon and Title */}
              <div class="flex items-center gap-3 mb-4">
                <div class={`w-12 h-12 rounded-xl ${colorStyle.iconBg} flex items-center justify-center shadow-md`}>
                  <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <Fragment set:html={path.icon} />
                  </svg>
                </div>
                <div>
                  <h5 class="font-bold text-lg text-gray-900 dark:text-gray-100">{path.title}</h5>
                  <div class={`text-xs ${colorStyle.text} font-medium`}>
                    {path.subtitle}
                  </div>
                </div>
              </div>

              {/* Description */}
              <p class="text-gray-700 dark:text-gray-300 leading-relaxed mb-4 text-sm">
                {path.description}
              </p>

              {/* Strengths */}
              <div class="mb-4">
                <h6 class="text-sm font-semibold text-gray-800 dark:text-gray-200 flex items-center gap-1 mb-2">
                  <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                  </svg>
                  Strengths:
                </h6>
                <div class="space-y-1.5">
                  {path.strengths.map((strength: string) => (
                    <div class="flex items-start gap-2 text-xs">
                      <div class={`w-1.5 h-1.5 rounded-full mt-1.5 flex-shrink-0 ${colorStyle.dot}`}></div>
                      <span class="text-gray-700 dark:text-gray-300 leading-relaxed">{strength}</span>
                    </div>
                  ))}
                </div>
              </div>

              {/* Tradeoffs */}
              <div class="mb-4">
                <h6 class="text-sm font-semibold text-gray-800 dark:text-gray-200 flex items-center gap-1 mb-2">
                  <svg class="w-4 h-4 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                  </svg>
                  Tradeoffs:
                </h6>
                <div class="space-y-1.5">
                  {path.tradeoffs.map((tradeoff: string) => (
                    <div class="flex items-start gap-2 text-xs">
                      <div class="w-1.5 h-1.5 rounded-full mt-1.5 flex-shrink-0 bg-amber-500"></div>
                      <span class="text-gray-600 dark:text-gray-400 leading-relaxed">{tradeoff}</span>
                    </div>
                  ))}
                </div>
              </div>

              {/* Examples */}
              <div class="pt-3 border-t border-gray-200 dark:border-gray-700">
                <h6 class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-2">
                  Examples:
                </h6>
                <div class="flex flex-wrap gap-1">
                  {path.examples.map((example: string) => (
                    <span class={`text-xs px-2 py-1 rounded-full ${colorStyle.badge} bg-opacity-20 ${colorStyle.text} font-medium`}>
                      {example}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        );
      })}
    </div>

    {/* Insight Note */}
    <div class="mt-6 p-4 bg-purple-50 dark:bg-purple-950/30 border border-purple-200 dark:border-purple-800/40 rounded-lg">
      <div class="flex items-start gap-3">
        <svg class="w-5 h-5 text-purple-600 dark:text-purple-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
        </svg>
        <div class="text-sm">
          <p class="text-purple-800 dark:text-purple-200 font-medium mb-1">The Key Insight</p>
          <p class="text-purple-700 dark:text-purple-300 leading-relaxed">
            AI doesn't force you to choose between these paths—it enables a new synthesis.
            The Player-Coach combines the <strong>output capacity</strong> of a Super IC with the <strong>strategic judgment</strong> of a Product Engineer and the <strong>organizational context</strong> of a traditional lead.
          </p>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  function initThreePaths() {
    const toggle = document.getElementById('paths-toggle');
    const content = document.getElementById('paths-content');
    const icon = document.getElementById('paths-toggle-icon');
    const text = document.getElementById('paths-toggle-text');

    if (!toggle || !content || !icon || !text) return;

    let isExpanded = false;

    toggle.addEventListener('click', () => {
      isExpanded = !isExpanded;

      if (isExpanded) {
        content.classList.remove('hidden');
        content.style.maxHeight = content.scrollHeight + 'px';
        icon.style.transform = 'rotate(0deg)';
        text.textContent = 'Hide Comparison';
        toggle.setAttribute('aria-expanded', 'true');
      } else {
        content.style.maxHeight = '0px';
        icon.style.transform = 'rotate(180deg)';
        text.textContent = 'Show Comparison';
        toggle.setAttribute('aria-expanded', 'false');

        setTimeout(() => {
          content.classList.add('hidden');
        }, 300);
      }
    });
  }

  // Initialize on load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initThreePaths);
  } else {
    initThreePaths();
  }

  // Re-initialize on navigation (for SPAs)
  (globalThis as any).initThreePaths = initThreePaths;
</script>

<style>
  .path-card {
    transition: all 0.3s ease;
  }

  .path-card:hover {
    transform: translateY(-4px);
  }

  #paths-content {
    transition: max-height 0.3s ease-out;
  }
</style>

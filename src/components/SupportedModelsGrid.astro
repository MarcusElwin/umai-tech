---
import CardCarousel from './CardCarousel.astro';

export interface ProviderModels {
  provider: string;
  badge?: string;
  families: string[];
  notes?: string;
}

export interface Props {
  title?: string;
  subtitle?: string;
  providers: ProviderModels[];
  footnote?: string;
}

const { title, subtitle, providers, footnote } = Astro.props;
---

<div class="supported-models">
  <CardCarousel title={title} subtitle={subtitle} ariaLabel="Supported model providers">
    {providers.map((p) => (
      <article class="px-3 sm:px-5 py-3 sm:py-4">
        <div class="rounded-xl ring-1 ring-gray-200/60 dark:ring-gray-700/50 bg-gray-50/40 dark:bg-gray-900/40 p-4 sm:p-5">
          <header class="flex items-baseline justify-between gap-3 mb-3">
            <h5 class="text-lg sm:text-xl font-bold text-gray-900 dark:text-white leading-tight">{p.provider}</h5>
            {p.badge && (
              <span class="flex-shrink-0 text-[9px] font-bold uppercase tracking-wider px-1.5 py-0.5 rounded bg-purple-100 dark:bg-purple-900/40 text-purple-700 dark:text-purple-300">
                {p.badge}
              </span>
            )}
          </header>

          <div>
            <div class="text-[10px] uppercase tracking-wider font-bold text-gray-500 dark:text-gray-500 mb-1.5">
              Model families
            </div>
            <ul class="grid sm:grid-cols-2 gap-y-1 gap-x-4 list-none p-0 m-0">
              {p.families.map((f) => (
                <li class="flex items-start gap-2 list-none">
                  <span class="inline-block w-1 h-1 rounded-full bg-purple-500 mt-2 flex-shrink-0" aria-hidden="true"></span>
                  <span class="text-sm font-mono text-gray-800 dark:text-gray-200 leading-snug">{f}</span>
                </li>
              ))}
            </ul>
          </div>

          {p.notes && (
            <div class="mt-3 pt-3 border-t border-gray-200/60 dark:border-gray-700/40 text-xs text-gray-500 dark:text-gray-500 italic leading-snug">
              {p.notes}
            </div>
          )}
        </div>
      </article>
    ))}
  </CardCarousel>

  {footnote && (
    <p class="mt-3 text-xs text-gray-500 dark:text-gray-500 italic">
      {footnote}
    </p>
  )}
</div>

<style>
  .supported-models ul { padding-left: 0 !important; }
  .supported-models ul li::marker { content: '' !important; }
</style>

---
export interface Crate {
  name: string;
  role: string;
  detail?: string;
  /** Additional fields revealed on click */
  modules?: string[];          // key files / submodules in the crate
  deps?: string[];             // what this crate depends on (workspace-internal)
  exposes?: string[];          // bullet-points of what's exported
  testCount?: string;          // e.g. "60+ type tests"
  source?: string;             // relative path under crates/
}

export interface StackItem {
  name: string;
  purpose: string;
  link?: string;
}

export interface Props {
  title?: string;
  subtitle?: string;
  crates: Crate[];
  stack?: StackItem[];
  footnote?: string;
}

const { title, subtitle, crates, stack, footnote } = Astro.props;
const id = `cw-${Math.random().toString(36).slice(2, 9)}`;
---

<div class="crate-workspace my-10 rounded-2xl ring-1 ring-gray-200/60 dark:ring-gray-700/50 bg-white dark:bg-gray-900/40 overflow-hidden" data-cw-id={id}>
  {(title || subtitle) && (
    <div class="px-6 pt-5 pb-3 border-b border-gray-200/60 dark:border-gray-700/40 flex items-baseline justify-between gap-3 flex-wrap">
      <div>
        {title && <h4 class="text-base font-bold text-gray-900 dark:text-white">{title}</h4>}
        {subtitle && <p class="text-xs text-gray-500 dark:text-gray-500 mt-0.5">{subtitle}</p>}
      </div>
      <div class="flex items-center gap-3">
        <span class="hidden sm:inline-block font-mono text-[10px] uppercase tracking-widest text-purple-600 dark:text-purple-400">
          Cargo workspace
        </span>
        <span class="text-[10px] text-gray-500 dark:text-gray-500 italic">
          Click any crate for detail
        </span>
      </div>
    </div>
  )}

  {/* Crates grid — each is a button that reveals a detail panel below */}
  <div class="grid sm:grid-cols-2 gap-px bg-gray-200/60 dark:bg-gray-700/40">
    {crates.map((c, i) => (
      <button
        type="button"
        data-cw-crate={i}
        data-cw-data={JSON.stringify(c)}
        class="cw-crate text-left bg-white dark:bg-gray-900/40 p-5 flex flex-col cursor-pointer transition focus:outline-none"
        aria-expanded="false"
      >
        <div class="flex items-baseline gap-2 mb-2">
          <span class="font-mono text-sm font-bold text-purple-700 dark:text-purple-300">{c.name}</span>
          <span class="font-mono text-[10px] text-gray-400 dark:text-gray-500">crate</span>
          <span class="ml-auto text-[10px] text-gray-400 dark:text-gray-500 font-mono opacity-0 group-hover:opacity-100 cw-hint">↓ detail</span>
        </div>
        <p class="text-sm font-semibold text-gray-900 dark:text-white mb-1.5 leading-snug">{c.role}</p>
        {c.detail && (
          <p class="text-xs text-gray-600 dark:text-gray-400 leading-snug">{c.detail}</p>
        )}
      </button>
    ))}
  </div>

  {/* Detail panel — filled by JS on click */}
  <div class="cw-detail-panel hidden border-t border-purple-300/60 dark:border-purple-700/50 bg-purple-50/30 dark:bg-purple-950/30 p-5">
    <div class="flex items-baseline justify-between mb-3 gap-3 flex-wrap">
      <div class="min-w-0">
        <div class="flex items-baseline gap-2 flex-wrap">
          <h5 class="cw-detail-name font-mono text-base font-bold text-purple-700 dark:text-purple-200">—</h5>
          <span class="cw-detail-source text-[10px] font-mono text-gray-500 dark:text-gray-500"></span>
        </div>
        <p class="cw-detail-role text-sm font-semibold text-gray-900 dark:text-white mt-1">—</p>
      </div>
      <button type="button" class="cw-detail-close text-xs font-mono text-purple-600 dark:text-purple-400 hover:underline flex-shrink-0">
        Close detail ✕
      </button>
    </div>
    <p class="cw-detail-blurb text-sm text-gray-700 dark:text-gray-300 leading-relaxed mb-4">—</p>

    {/* Three optional sub-blocks: modules / deps / exposes */}
    <div class="grid sm:grid-cols-3 gap-4">
      <div class="cw-detail-modules-wrap hidden">
        <div class="text-[10px] uppercase tracking-wider font-bold text-gray-500 dark:text-gray-500 mb-1.5">Modules</div>
        <ul class="cw-detail-modules list-none p-0 m-0 space-y-1"></ul>
      </div>
      <div class="cw-detail-deps-wrap hidden">
        <div class="text-[10px] uppercase tracking-wider font-bold text-gray-500 dark:text-gray-500 mb-1.5">Depends on</div>
        <ul class="cw-detail-deps list-none p-0 m-0 space-y-1"></ul>
      </div>
      <div class="cw-detail-exposes-wrap hidden">
        <div class="text-[10px] uppercase tracking-wider font-bold text-gray-500 dark:text-gray-500 mb-1.5">Exposes</div>
        <ul class="cw-detail-exposes list-none p-0 m-0 space-y-1"></ul>
      </div>
    </div>

    <div class="cw-detail-tests-wrap hidden mt-4 pt-3 border-t border-purple-200/40 dark:border-purple-700/30">
      <span class="text-[10px] uppercase tracking-widest font-bold text-purple-600 dark:text-purple-400">Tests · </span>
      <span class="cw-detail-tests text-xs font-mono text-gray-700 dark:text-gray-300"></span>
    </div>
  </div>

  {/* Stack footer */}
  {stack && stack.length > 0 && (
    <div class="px-5 py-4 bg-gray-50/60 dark:bg-gray-900/60 border-t border-gray-200/60 dark:border-gray-700/40">
      <div class="text-[10px] uppercase tracking-widest font-bold text-gray-500 dark:text-gray-400 mb-2">
        Stack
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-2">
        {stack.map((s) => (
          <div class="cw-stack rounded-lg bg-white dark:bg-gray-900/40 ring-1 ring-gray-200/60 dark:ring-gray-700/50 px-2.5 py-2">
            {s.link ? (
              <a href={s.link} target="_blank" rel="noopener" class="block hover:no-underline">
                <div class="font-mono text-xs font-bold text-purple-700 dark:text-purple-300 leading-tight">{s.name}</div>
                <div class="text-[10px] text-gray-500 dark:text-gray-500 mt-0.5 leading-tight">{s.purpose}</div>
              </a>
            ) : (
              <>
                <div class="font-mono text-xs font-bold text-purple-700 dark:text-purple-300 leading-tight">{s.name}</div>
                <div class="text-[10px] text-gray-500 dark:text-gray-500 mt-0.5 leading-tight">{s.purpose}</div>
              </>
            )}
          </div>
        ))}
      </div>
    </div>
  )}

  {footnote && (
    <div class="px-5 py-3 text-xs italic text-gray-500 dark:text-gray-500 border-t border-gray-200/60 dark:border-gray-700/40">
      {footnote}
    </div>
  )}
</div>

<script is:inline define:vars={{ id, crates }}>
  (function () {
    const root = document.querySelector(`[data-cw-id="${id}"]`);
    if (!root) return;

    const panel = root.querySelector('.cw-detail-panel');
    const nameEl = root.querySelector('.cw-detail-name');
    const sourceEl = root.querySelector('.cw-detail-source');
    const roleEl = root.querySelector('.cw-detail-role');
    const blurbEl = root.querySelector('.cw-detail-blurb');
    const modulesWrap = root.querySelector('.cw-detail-modules-wrap');
    const modulesEl = root.querySelector('.cw-detail-modules');
    const depsWrap = root.querySelector('.cw-detail-deps-wrap');
    const depsEl = root.querySelector('.cw-detail-deps');
    const exposesWrap = root.querySelector('.cw-detail-exposes-wrap');
    const exposesEl = root.querySelector('.cw-detail-exposes');
    const testsWrap = root.querySelector('.cw-detail-tests-wrap');
    const testsEl = root.querySelector('.cw-detail-tests');
    const closeBtn = root.querySelector('.cw-detail-close');

    function clearActive() {
      root.querySelectorAll('[data-cw-crate]').forEach((b) => {
        b.classList.remove('cw-crate-active');
        b.setAttribute('aria-expanded', 'false');
      });
    }

    function fillList(ul, items, mono) {
      if (!ul) return;
      ul.innerHTML = '';
      (items || []).forEach((it) => {
        const li = document.createElement('li');
        li.className = mono
          ? 'text-xs font-mono text-gray-700 dark:text-gray-300 leading-snug flex gap-1.5'
          : 'text-xs text-gray-700 dark:text-gray-300 leading-snug flex gap-1.5';
        li.innerHTML = '<span class="text-purple-500 flex-shrink-0">·</span><span>' + it + '</span>';
        ul.appendChild(li);
      });
    }

    function show(i) {
      const c = crates[i];
      if (!c) return;
      clearActive();
      const btn = root.querySelector('[data-cw-crate="' + i + '"]');
      if (btn) {
        btn.classList.add('cw-crate-active');
        btn.setAttribute('aria-expanded', 'true');
      }
      if (nameEl) nameEl.textContent = c.name;
      if (roleEl) roleEl.textContent = c.role;
      if (blurbEl) blurbEl.textContent = c.detail || '';
      if (sourceEl) sourceEl.textContent = c.source ? c.source : '';

      if (c.modules && c.modules.length && modulesWrap && modulesEl) {
        fillList(modulesEl, c.modules, true);
        modulesWrap.classList.remove('hidden');
      } else if (modulesWrap) {
        modulesWrap.classList.add('hidden');
      }
      if (c.deps && c.deps.length && depsWrap && depsEl) {
        fillList(depsEl, c.deps, true);
        depsWrap.classList.remove('hidden');
      } else if (depsWrap) {
        depsWrap.classList.add('hidden');
      }
      if (c.exposes && c.exposes.length && exposesWrap && exposesEl) {
        fillList(exposesEl, c.exposes, false);
        exposesWrap.classList.remove('hidden');
      } else if (exposesWrap) {
        exposesWrap.classList.add('hidden');
      }
      if (c.testCount && testsWrap && testsEl) {
        testsEl.textContent = c.testCount;
        testsWrap.classList.remove('hidden');
      } else if (testsWrap) {
        testsWrap.classList.add('hidden');
      }

      if (panel) {
        panel.classList.remove('hidden');
        panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
    }

    function close() {
      clearActive();
      if (panel) panel.classList.add('hidden');
    }

    root.querySelectorAll('[data-cw-crate]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const idx = parseInt(btn.getAttribute('data-cw-crate') || '0', 10);
        show(idx);
      });
    });
    if (closeBtn) closeBtn.addEventListener('click', close);
  })();
</script>

<style>
  .crate-workspace .cw-crate {
    transition: background-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }
  .crate-workspace .cw-crate:hover {
    background-color: rgba(139, 92, 246, 0.04);
  }
  :global(.dark) .crate-workspace .cw-crate:hover {
    background-color: rgba(139, 92, 246, 0.08);
  }
  .crate-workspace .cw-crate:focus-visible {
    outline: 2px solid rgb(139 92 246);
    outline-offset: -2px;
  }
  .crate-workspace .cw-crate.cw-crate-active {
    background-color: rgba(139, 92, 246, 0.08);
    box-shadow: inset 0 -3px 0 0 rgb(139 92 246 / 0.6);
  }
  :global(.dark) .crate-workspace .cw-crate.cw-crate-active {
    background-color: rgba(139, 92, 246, 0.15);
  }
  .crate-workspace .cw-stack {
    transition: transform 0.2s ease;
  }
  .crate-workspace .cw-stack:hover {
    transform: translateY(-1px);
  }
  @media (prefers-reduced-motion: reduce) {
    .crate-workspace .cw-crate,
    .crate-workspace .cw-stack {
      transition: none;
    }
    .crate-workspace .cw-stack:hover { transform: none; }
  }
</style>

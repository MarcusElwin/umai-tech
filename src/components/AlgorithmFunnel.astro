---
export interface Props {
  title?: string;
  stages: Array<{
    name: string;
    count: number;
    description: string;
    color: string;
  }>;
}

const { title = "Recommendation Pipeline", stages } = Astro.props;
---

<div class="algorithm-funnel my-8">
  <h3 class="text-lg font-semibold mb-6 text-gray-900 dark:text-white flex items-center gap-2">
    <svg class="w-5 h-5 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
    </svg>
    {title}
  </h3>

  <div class="funnel-container relative space-y-4">
    {stages.map((stage, i) => {
      const widthPercent = 100 - (i * (60 / stages.length));
      const animationDelay = i * 150;

      return (
        <div
          class="funnel-stage opacity-0"
          style={`--stage-color: ${stage.color}; --animation-delay: ${animationDelay}ms;`}
          data-stage-index={i}
        >
          <div class="stage-wrapper flex justify-center">
            <div
              class="stage-bar relative overflow-hidden rounded-lg shadow-lg transition-all duration-300 hover:shadow-xl hover:scale-[1.02] cursor-pointer"
              style={`width: ${widthPercent}%; background: linear-gradient(135deg, ${stage.color}, ${stage.color}dd);`}
              data-count={stage.count}
            >
              <div class="stage-content flex items-center justify-between px-4 py-3 text-white">
                <span class="stage-name font-semibold text-sm md:text-base">{stage.name}</span>
                <span class="stage-count font-mono text-lg md:text-xl font-bold">
                  {stage.count.toLocaleString()}
                </span>
              </div>

              <!-- Animated shine effect -->
              <div class="shine-effect absolute inset-0 pointer-events-none"></div>
            </div>
          </div>

          <p class="stage-description text-center text-sm text-gray-600 dark:text-gray-400 mt-2 max-w-md mx-auto">
            {stage.description}
          </p>

          {/* Connector with reduction percentage */}
          {i < stages.length - 1 && (
            <div class="connector flex flex-col items-center my-3">
              <div class="reduction-badge flex items-center gap-2 px-3 py-1 bg-gray-100 dark:bg-gray-800 rounded-full text-xs font-medium text-gray-600 dark:text-gray-400 border border-gray-200 dark:border-gray-700">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
                </svg>
                <span class="font-mono">
                  -{((1 - stages[i + 1].count / stage.count) * 100).toFixed(0)}%
                </span>
                <span class="text-gray-400">filtered</span>
              </div>
            </div>
          )}
        </div>
      );
    })}

    {/* Summary stats - more prominent */}
    <div class="funnel-summary mt-8 p-4 bg-gradient-to-r from-purple-50 to-blue-50 dark:from-purple-900/30 dark:to-blue-900/30 rounded-xl border border-purple-200/50 dark:border-purple-700/50">
      <h4 class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-3 text-center">Pipeline Summary</h4>
      <div class="flex justify-center items-center gap-8">
        <div class="stat-item text-center">
          <span class="block text-3xl font-bold text-purple-600 dark:text-purple-400">
            {stages[0]?.count.toLocaleString()}
          </span>
          <span class="text-sm text-gray-500 dark:text-gray-400">Candidates In</span>
        </div>
        <div class="stat-arrow text-gray-300 dark:text-gray-600">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </div>
        <div class="stat-item text-center">
          <span class="block text-3xl font-bold text-blue-600 dark:text-blue-400">
            {stages[stages.length - 1]?.count.toLocaleString()}
          </span>
          <span class="text-sm text-gray-500 dark:text-gray-400">Shown to User</span>
        </div>
        <div class="stat-divider w-px h-12 bg-gray-200 dark:bg-gray-700 mx-2"></div>
        <div class="stat-item text-center px-4 py-2 bg-white dark:bg-gray-800 rounded-lg shadow-sm">
          <span class="block text-2xl font-mono font-bold text-blue-600 dark:text-blue-400">
            {(stages[0]?.count / stages[stages.length - 1]?.count).toFixed(0)}:1
          </span>
          <span class="text-xs text-gray-500 dark:text-gray-400">Selectivity</span>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  function initAlgorithmFunnel() {
    const stages = document.querySelectorAll('.funnel-stage');

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const stage = entry.target as HTMLElement;
          const delay = parseInt(stage.style.getPropertyValue('--animation-delay') || '0');

          setTimeout(() => {
            stage.classList.remove('opacity-0');
            stage.classList.add('animate-fade-in-up');
          }, delay);

          observer.unobserve(stage);
        }
      });
    }, { threshold: 0.2 });

    stages.forEach(stage => observer.observe(stage));

    // Add hover interaction for count animation
    const bars = document.querySelectorAll('.stage-bar');
    bars.forEach(bar => {
      bar.addEventListener('mouseenter', () => {
        const countEl = bar.querySelector('.stage-count') as HTMLElement;
        if (countEl) {
          countEl.classList.add('scale-110');
        }
      });

      bar.addEventListener('mouseleave', () => {
        const countEl = bar.querySelector('.stage-count') as HTMLElement;
        if (countEl) {
          countEl.classList.remove('scale-110');
        }
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAlgorithmFunnel);
  } else {
    initAlgorithmFunnel();
  }

  (globalThis as any).initAlgorithmFunnel = initAlgorithmFunnel;
</script>

<style>
  .algorithm-funnel {
    @apply bg-gradient-to-br from-gray-50 to-white dark:from-gray-900/50 dark:to-gray-800/30;
    @apply border border-gray-200 dark:border-gray-700 rounded-xl p-6;
  }

  .stage-bar {
    transition: all 0.3s ease;
  }

  .stage-count {
    transition: transform 0.2s ease;
  }

  .shine-effect {
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.2) 50%,
      transparent 100%
    );
    transform: translateX(-100%);
  }

  .stage-bar:hover .shine-effect {
    animation: shine 0.6s ease-in-out;
  }

  @keyframes shine {
    from {
      transform: translateX(-100%);
    }
    to {
      transform: translateX(100%);
    }
  }

  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in-up {
    animation: fade-in-up 0.5s ease-out forwards;
  }

  @keyframes bounce-subtle {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(3px);
    }
  }

  .animate-bounce-subtle {
    animation: bounce-subtle 1.5s ease-in-out infinite;
  }
</style>

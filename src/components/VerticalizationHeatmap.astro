  .cell-btn {
    cursor: pointer;
  }

  .cell-btn:focus {
    outline: none;
    ring: 2px solid theme('colors.purple.500');
  }

  /* Sticky column on mobile */
  @media (max-width: 768px) {
    th:first-child,
    td:first-child {
      position: sticky;
      left: 0;
      z-index: 10;
    }
  }

  /* Smooth modal fade-in */
  #verticalization-heatmap [id$="-modal"] {
    animation: fadeIn 0.2s ease-out;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
</style>

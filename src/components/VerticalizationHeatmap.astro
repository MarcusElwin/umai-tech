---
export interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = 'Platform Giants: Verticalization Risk Matrix',
  subtitle = 'How OpenAI, Anthropic, and Google are entering vertical markets (April 2026)'
} = Astro.props;

const componentId = `vertical-heatmap-${Math.random().toString(36).slice(2, 11)}`;

// Verticalization data: [vertical, openai, anthropic, google]
// Each entry: { play: string, risk: 0-100, date: string, details: string, source: string }
// SVG icon components
const icons = {
  legal: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"/></svg>',
  design: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/></svg>',
  coding: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>',
  healthcare: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>',
  finance: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>',
  commerce: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>',
  target: '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>',
  openai: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>',
  anthropic: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>',
  google: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>',
};

const verticals = [
  {
    name: 'Legal',
    icon: 'legal',
    openai: { play: '—', risk: 15, date: '', details: 'No major play yet, but GPT-4 Legal API exists', source: '' },
    anthropic: {
      play: 'Claude Legal + Word',
      risk: 95,
      date: 'Feb 2026',
      details: 'Contract review, NDA triage, compliance tracking. Caused $285B market cap wipeout (Thomson Reuters -16%, RELX -14%, Wolters Kluwer -13%)',
      source: 'Artificial Lawyer, Feb 2026; Law.com Legal Tech News, Feb 2026; LawSites, Feb 2026'
    },
    google: { play: 'Gemini for Lawyers', risk: 45, date: '2025-26', details: 'Case law research, contract drafting in Workspace', source: 'Spellbook Legal, 2026 Guide' }
  },
  {
    name: 'Design',
    icon: 'design',
    openai: { play: '—', risk: 10, date: '', details: 'DALL-E 3 in ChatGPT, but no dedicated design tool', source: '' },
    anthropic: {
      play: 'Claude Design',
      risk: 85,
      date: 'April 17, 2026',
      details: 'UI/UX design app, Figma plugin, Code to Canvas. Figma stock fell 7% at launch. CPO Mike Krieger stepped down from Figma board 3 days earlier.',
      source: 'Figma Blog, Feb 2026; Sherwood News, April 2026; Gizmodo, April 2026; The New Stack, April 2026'
    },
    google: { play: '—', risk: 20, date: '', details: 'Imagen 3 for creative workflows, no dedicated tool', source: '' }
  },
  {
    name: 'Coding',
    icon: 'coding',
    openai: {
      play: 'Windsurf IDE',
      risk: 80,
      date: '2025',
      details: 'Acquired Codeium/Windsurf for $3B. AI-native IDE competing with Cursor, VS Code',
      source: 'StartupHub.ai, 2026; How They Grow, 2026'
    },
    anthropic: { play: 'Claude Code', risk: 75, date: '2025-26', details: 'Official CLI + VS Code extension. Direct competition with Cursor', source: 'Claude Code Documentation, 2025-26' },
    google: { play: 'Gemini Code Assist', risk: 65, date: '2025-26', details: 'Enterprise code completion, cloud IDE integration', source: 'Google Cloud Blog, 2026' }
  },
  {
    name: 'Healthcare',
    icon: 'healthcare',
    openai: {
      play: 'Torch Health',
      risk: 70,
      date: 'Jan 2026',
      details: 'Acquired for $100M. AI triage, symptom guidance, wellness tracking',
      source: 'StartupHub.ai, Jan 2026; Leonis Capital Research, 2026'
    },
    anthropic: { play: '—', risk: 25, date: '', details: 'HIPAA-compliant Claude available, but no vertical product', source: '' },
    google: { play: 'Gemini Healthcare', risk: 60, date: '2025-26', details: 'Research agents, clinical decision support, air-gapped deployments', source: 'Google Cloud Next26; SiliconANGLE, April 2026' }
  },
  {
    name: 'Finance',
    icon: 'finance',
    openai: {
      play: 'Hiro Finance',
      risk: 75,
      date: 'April 14, 2026',
      details: 'Acquired autonomous personal finance startup. Integration in ChatGPT Plus Q3 2026. Part of broader "Everything Platform" strategy.',
      source: 'FinancialContent, April 14 2026; Market Minute, April 2026'
    },
    anthropic: { play: '—', risk: 30, date: '', details: 'Enterprise deployments at financial institutions, no vertical product', source: '' },
    google: {
      play: 'Gemini for Finance',
      risk: 55,
      date: '2026',
      details: 'Citi Sky partnership, Sheets/Drive integration, 2nd most adopted AI in US finance teams per Gartner',
      source: 'ChatFin.ai CFO Guide 2026; Google Workspace Blog, 2026'
    }
  },
  {
    name: 'Commerce',
    icon: 'commerce',
    openai: {
      play: 'Shopify Partnership',
      risk: 65,
      date: '2025-26',
      details: 'In-chat product discovery and purchase, ~4% commission on sales',
      source: 'ARK Invest Newsletter #495, 2026'
    },
    anthropic: { play: '—', risk: 15, date: '', details: 'No major commerce play announced', source: '' },
    google: { play: 'Shopping Graph', risk: 50, date: '2025-26', details: 'Google Shopping integration with Gemini, merchant tools', source: 'Google Cloud Blog, 2025-26' }
  }
];

// Purple gradient color scale - elegant and unified
const getRiskColor = (risk: number) => {
  if (risk >= 80) return {
    bg: 'bg-gradient-to-br from-purple-500/20 via-purple-600/15 to-fuchsia-500/20 dark:from-purple-500/30 dark:via-purple-600/25 dark:to-fuchsia-500/30',
    text: 'text-purple-900 dark:text-purple-100',
    border: 'border-purple-300/40 dark:border-purple-600/40',
    intensity: 'font-black text-2xl',
    scoreGradient: 'bg-gradient-to-br from-purple-600 via-fuchsia-600 to-purple-700 bg-clip-text text-transparent'
  };
  if (risk >= 60) return {
    bg: 'bg-gradient-to-br from-purple-400/15 via-purple-500/10 to-violet-400/15 dark:from-purple-400/25 dark:via-purple-500/20 dark:to-violet-400/25',
    text: 'text-purple-800 dark:text-purple-200',
    border: 'border-purple-300/30 dark:border-purple-600/30',
    intensity: 'font-bold text-xl',
    scoreGradient: 'bg-gradient-to-br from-purple-500 via-violet-500 to-purple-600 bg-clip-text text-transparent'
  };
  if (risk >= 40) return {
    bg: 'bg-gradient-to-br from-purple-300/10 via-purple-400/8 to-indigo-300/10 dark:from-purple-300/20 dark:via-purple-400/15 dark:to-indigo-300/20',
    text: 'text-purple-700 dark:text-purple-300',
    border: 'border-purple-200/30 dark:border-purple-700/30',
    intensity: 'font-semibold text-lg',
    scoreGradient: 'bg-gradient-to-br from-purple-400 via-indigo-400 to-purple-500 bg-clip-text text-transparent'
  };
  if (risk >= 20) return {
    bg: 'bg-gradient-to-br from-purple-200/8 via-purple-300/5 to-slate-200/8 dark:from-purple-200/15 dark:via-purple-300/10 dark:to-slate-200/15',
    text: 'text-purple-600 dark:text-purple-400',
    border: 'border-purple-200/20 dark:border-purple-700/20',
    intensity: 'font-medium text-base',
    scoreGradient: 'bg-gradient-to-br from-purple-300 via-slate-400 to-purple-400 bg-clip-text text-transparent'
  };
  return {
    bg: 'bg-gradient-to-br from-gray-100/50 to-gray-200/50 dark:from-gray-800/50 dark:to-gray-900/50',
    text: 'text-gray-500 dark:text-gray-500',
    border: 'border-gray-300/30 dark:border-gray-700/30',
    intensity: 'font-normal text-sm',
    scoreGradient: 'text-gray-400 dark:text-gray-600'
  };
};
---

<div class="verticalization-heatmap my-12" id={componentId}>
  {/* Header */}
  <div class="text-center mb-10">
    <h4 class="text-2xl font-bold text-gray-900 dark:text-white mb-3">{title}</h4>
    {subtitle && <p class="text-sm text-gray-600 dark:text-gray-400 max-w-2xl mx-auto leading-relaxed">{subtitle}</p>}
  </div>

  {/* Heatmap Container */}
  <div class="bg-white dark:bg-gray-800 rounded-2xl border border-gray-200/50 dark:border-gray-700/50 shadow-lg overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full border-collapse">
        <thead>
          <tr class="border-b border-gray-200 dark:border-gray-700">
            <th class="p-5 text-left font-semibold text-gray-700 dark:text-gray-300 bg-gray-50/50 dark:bg-gray-900/30 sticky left-0 z-10">
              <div class="flex items-center gap-2.5">
                <span class="text-gray-500 dark:text-gray-400" set:html={icons.target} />
                <span class="text-sm">Vertical</span>
              </div>
            </th>
            <th class="p-5 text-center font-semibold text-gray-700 dark:text-gray-300 bg-gray-50/50 dark:bg-gray-900/30 min-w-[200px]">
              <div class="flex flex-col items-center gap-1">
                <div class="flex items-center gap-2">
                  <span class="text-gray-500 dark:text-gray-400" set:html={icons.openai} />
                  <span class="text-sm">OpenAI</span>
                </div>
                <span class="text-xs font-normal text-gray-500 dark:text-gray-500">$852B valuation</span>
              </div>
            </th>
            <th class="p-5 text-center font-semibold text-gray-700 dark:text-gray-300 bg-gray-50/50 dark:bg-gray-900/30 min-w-[200px]">
              <div class="flex flex-col items-center gap-1">
                <div class="flex items-center gap-2">
                  <span class="text-gray-500 dark:text-gray-400" set:html={icons.anthropic} />
                  <span class="text-sm">Anthropic</span>
                </div>
                <span class="text-xs font-normal text-gray-500 dark:text-gray-500">Claude Opus 4.7</span>
              </div>
            </th>
            <th class="p-5 text-center font-semibold text-gray-700 dark:text-gray-300 bg-gray-50/50 dark:bg-gray-900/30 min-w-[200px]">
              <div class="flex flex-col items-center gap-1">
                <div class="flex items-center gap-2">
                  <span class="text-gray-500 dark:text-gray-400" set:html={icons.google} />
                  <span class="text-sm">Google</span>
                </div>
                <span class="text-xs font-normal text-gray-500 dark:text-gray-500">Gemini 3.1 Pro</span>
              </div>
            </th>
          </tr>
        </thead>
        <tbody>
          {verticals.map((vertical, i) => (
            <tr class={`border-b border-gray-100 dark:border-gray-700/50 transition-all duration-150 ${i % 2 === 0 ? 'bg-white dark:bg-gray-800/30' : 'bg-gray-50/30 dark:bg-gray-800/10'}`}>
              {/* Vertical name */}
              <td class="p-5 font-semibold text-gray-900 dark:text-white bg-gradient-to-r from-gray-50 to-white dark:from-gray-900/50 dark:to-gray-800/50 sticky left-0 z-10">
                <div class="flex items-center gap-3">
                  <span class="text-gray-700 dark:text-gray-300" set:html={icons[vertical.icon]} />
                  <span>{vertical.name}</span>
                </div>
              </td>

              {/* OpenAI cell */}
              <td class="p-3">
                <button
                  class={`cell-btn w-full text-left p-5 rounded-lg border backdrop-blur-sm transition-all duration-200 hover:scale-[1.02] hover:shadow-purple-200/30 dark:hover:shadow-purple-900/30 ${getRiskColor(vertical.openai.risk).bg} ${getRiskColor(vertical.openai.risk).border}`}
                  data-heatmap-cell={componentId}
                  data-provider="OpenAI"
                  data-vertical={vertical.name}
                  data-icon={vertical.icon}
                  data-play={vertical.openai.play}
                  data-risk={vertical.openai.risk}
                  data-date={vertical.openai.date}
                  data-details={vertical.openai.details}
                  data-source={vertical.openai.source}
                >
                  <div class="flex items-start justify-between gap-4">
                    <div class="flex-1 min-w-0">
                      <div class={`font-semibold ${getRiskColor(vertical.openai.risk).text} mb-1.5 leading-tight`}>
                        {vertical.openai.play}
                      </div>
                      {vertical.openai.date && (
                        <div class="text-xs text-gray-600 dark:text-gray-500">
                          {vertical.openai.date}
                        </div>
                      )}
                    </div>
                    <div class={`flex-shrink-0 ${getRiskColor(vertical.openai.risk).intensity} ${getRiskColor(vertical.openai.risk).scoreGradient} tabular-nums`}>
                      {vertical.openai.risk}
                    </div>
                  </div>
                </button>
              </td>

              {/* Anthropic cell */}
              <td class="p-3">
                <button
                  class={`cell-btn w-full text-left p-5 rounded-lg border backdrop-blur-sm transition-all duration-200 hover:scale-[1.02] hover:shadow-purple-200/30 dark:hover:shadow-purple-900/30 ${getRiskColor(vertical.anthropic.risk).bg} ${getRiskColor(vertical.anthropic.risk).border}`}
                  data-heatmap-cell={componentId}
                  data-provider="Anthropic"
                  data-vertical={vertical.name}
                  data-icon={vertical.icon}
                  data-play={vertical.anthropic.play}
                  data-risk={vertical.anthropic.risk}
                  data-date={vertical.anthropic.date}
                  data-details={vertical.anthropic.details}
                  data-source={vertical.anthropic.source}
                >
                  <div class="flex items-start justify-between gap-4">
                    <div class="flex-1 min-w-0">
                      <div class={`font-semibold ${getRiskColor(vertical.anthropic.risk).text} mb-1.5 leading-tight`}>
                        {vertical.anthropic.play}
                      </div>
                      {vertical.anthropic.date && (
                        <div class="text-xs text-gray-600 dark:text-gray-500">
                          {vertical.anthropic.date}
                        </div>
                      )}
                    </div>
                    <div class={`flex-shrink-0 ${getRiskColor(vertical.anthropic.risk).intensity} ${getRiskColor(vertical.anthropic.risk).scoreGradient} tabular-nums`}>
                      {vertical.anthropic.risk}
                    </div>
                  </div>
                </button>
              </td>

              {/* Google cell */}
              <td class="p-3">
                <button
                  class={`cell-btn w-full text-left p-5 rounded-lg border backdrop-blur-sm transition-all duration-200 hover:scale-[1.02] hover:shadow-purple-200/30 dark:hover:shadow-purple-900/30 ${getRiskColor(vertical.google.risk).bg} ${getRiskColor(vertical.google.risk).border}`}
                  data-heatmap-cell={componentId}
                  data-provider="Google"
                  data-vertical={vertical.name}
                  data-icon={vertical.icon}
                  data-play={vertical.google.play}
                  data-risk={vertical.google.risk}
                  data-date={vertical.google.date}
                  data-details={vertical.google.details}
                  data-source={vertical.google.source}
                >
                  <div class="flex items-start justify-between gap-4">
                    <div class="flex-1 min-w-0">
                      <div class={`font-semibold ${getRiskColor(vertical.google.risk).text} mb-1.5 leading-tight`}>
                        {vertical.google.play}
                      </div>
                      {vertical.google.date && (
                        <div class="text-xs text-gray-600 dark:text-gray-500">
                          {vertical.google.date}
                        </div>
                      )}
                    </div>
                    <div class={`flex-shrink-0 ${getRiskColor(vertical.google.risk).intensity} ${getRiskColor(vertical.google.risk).scoreGradient} tabular-nums`}>
                      {vertical.google.risk}
                    </div>
                  </div>
                </button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

  </div>

  {/* Modal Dialog */}
  <div id={`${componentId}-modal`} class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-black/50 backdrop-blur-sm" style="display: none;">
    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-2xl max-w-2xl w-full max-h-[90vh] overflow-y-auto border border-gray-200 dark:border-gray-700">
      {/* Modal Header */}
      <div class="sticky top-0 bg-gradient-to-r from-purple-600 to-indigo-600 dark:from-purple-700 dark:to-indigo-700 px-6 py-5 rounded-t-2xl border-b border-purple-500 dark:border-purple-600">
        <div class="flex items-start justify-between gap-4">
          <div class="flex-1">
            <div class="flex items-center gap-3 mb-2">
              <span class="text-white w-8 h-8" id={`${componentId}-modal-icon`}></span>
              <div>
                <h3 class="text-2xl font-bold text-white" id={`${componentId}-modal-provider`}></h3>
                <p class="text-purple-100 text-sm font-medium" id={`${componentId}-modal-vertical`}></p>
              </div>
            </div>
          </div>
          <button
            id={`${componentId}-modal-close`}
            class="flex-shrink-0 text-white/80 hover:text-white hover:bg-white/10 rounded-lg p-2 transition-all"
            aria-label="Close dialog"
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
      </div>

      {/* Modal Body */}
      <div class="p-6 space-y-6">
        {/* Product & Risk Score */}
        <div class="flex items-start justify-between gap-4 pb-6 border-b border-gray-200 dark:border-gray-700">
          <div class="flex-1">
            <div class="text-sm text-gray-500 dark:text-gray-400 font-semibold mb-1">Product/Partnership</div>
            <div class="flex items-baseline gap-3">
              <h4 class="text-xl font-bold text-gray-900 dark:text-white" id={`${componentId}-modal-play`}></h4>
              <span class="text-sm text-gray-500 dark:text-gray-400 font-medium" id={`${componentId}-modal-date`}></span>
            </div>
          </div>
          <div class="flex-shrink-0 text-center px-6 py-4 rounded-xl bg-gradient-to-br from-purple-50 to-indigo-50 dark:from-purple-900/30 dark:to-indigo-900/30 border border-purple-200 dark:border-purple-800">
            <div class="text-5xl font-black bg-gradient-to-br from-purple-600 via-fuchsia-600 to-purple-700 bg-clip-text text-transparent" id={`${componentId}-modal-risk`}></div>
            <div class="text-xs text-gray-600 dark:text-gray-400 font-semibold mt-1">Risk Score</div>
          </div>
        </div>

        {/* Details */}
        <div>
          <div class="text-sm text-gray-500 dark:text-gray-400 font-semibold mb-3">Details</div>
          <p class="text-base text-gray-700 dark:text-gray-300 leading-relaxed" id={`${componentId}-modal-details`}></p>
        </div>

        {/* Sources */}
        <div id={`${componentId}-modal-source-section`} class="pt-4 border-t border-gray-200 dark:border-gray-700">
          <div class="text-sm text-gray-500 dark:text-gray-400 font-semibold mb-2">Sources</div>
          <div class="text-xs text-gray-600 dark:text-gray-400 leading-relaxed italic" id={`${componentId}-modal-source`}></div>
        </div>
      </div>
    </div>
  </div>

  {/* Legend */}
  <div class="mt-8 flex flex-wrap items-center justify-center gap-4 text-xs">
    <div class="font-semibold text-gray-700 dark:text-gray-300 text-sm">Risk Intensity:</div>
    <div class="flex items-center gap-2 px-3 py-1.5 rounded-lg bg-purple-500/10 dark:bg-purple-500/20 border border-purple-300/30 dark:border-purple-600/30">
      <div class="w-2.5 h-2.5 rounded-full bg-gradient-to-br from-purple-500 to-fuchsia-500"></div>
      <span class="font-medium text-gray-700 dark:text-gray-300">Critical (80+)</span>
    </div>
    <div class="flex items-center gap-2 px-3 py-1.5 rounded-lg bg-purple-400/10 dark:bg-purple-400/15 border border-purple-300/25 dark:border-purple-600/25">
      <div class="w-2.5 h-2.5 rounded-full bg-gradient-to-br from-purple-400 to-violet-400"></div>
      <span class="font-medium text-gray-700 dark:text-gray-300">High (60-79)</span>
    </div>
    <div class="flex items-center gap-2 px-3 py-1.5 rounded-lg bg-purple-300/10 dark:bg-purple-300/15 border border-purple-200/25 dark:border-purple-700/25">
      <div class="w-2.5 h-2.5 rounded-full bg-gradient-to-br from-purple-300 to-indigo-300"></div>
      <span class="font-medium text-gray-700 dark:text-gray-300">Medium (40-59)</span>
    </div>
    <div class="flex items-center gap-2 px-3 py-1.5 rounded-lg bg-purple-200/10 dark:bg-purple-200/15 border border-purple-200/20 dark:border-purple-700/20">
      <div class="w-2.5 h-2.5 rounded-full bg-gradient-to-br from-purple-200 to-slate-300"></div>
      <span class="font-medium text-gray-700 dark:text-gray-300">Low (20-39)</span>
    </div>
    <div class="flex items-center gap-2 px-3 py-1.5 rounded-lg bg-gray-100 dark:bg-gray-800 border border-gray-300/30 dark:border-gray-700/30">
      <div class="w-2.5 h-2.5 rounded-full bg-gradient-to-br from-gray-300 to-gray-400"></div>
      <span class="font-medium text-gray-700 dark:text-gray-300">Minimal (<20)</span>
    </div>
  </div>

  {/* Methodology */}
  <div class="mt-8 p-5 bg-gradient-to-br from-purple-50 to-indigo-50 dark:from-purple-900/10 dark:to-indigo-900/10 rounded-xl border border-purple-200 dark:border-purple-800/50">
    <p class="text-xs text-gray-700 dark:text-gray-300 leading-relaxed">
      <strong class="text-purple-700 dark:text-purple-300 text-sm">Methodology:</strong> Risk scores (0-100) assess the threat level each platform play poses to incumbent vertical SaaS providers, based on: market reaction (stock drops, market cap impact), strategic investment size, product maturity, distribution advantage, and timing. Click any cell to view detailed sources and analysis. Scores reflect verticalization risk as of April 2026.
    </p>
  </div>
</div>

<script define:vars={{ componentId, icons }}>
  (function() {
    const cells = document.querySelectorAll(`[data-heatmap-cell="${componentId}"]`);
    const modal = document.getElementById(`${componentId}-modal`);
    const modalClose = document.getElementById(`${componentId}-modal-close`);

    const modalProvider = document.getElementById(`${componentId}-modal-provider`);
    const modalVertical = document.getElementById(`${componentId}-modal-vertical`);
    const modalIcon = document.getElementById(`${componentId}-modal-icon`);
    const modalPlay = document.getElementById(`${componentId}-modal-play`);
    const modalDate = document.getElementById(`${componentId}-modal-date`);
    const modalDetails = document.getElementById(`${componentId}-modal-details`);
    const modalRisk = document.getElementById(`${componentId}-modal-risk`);
    const modalSource = document.getElementById(`${componentId}-modal-source`);
    const modalSourceSection = document.getElementById(`${componentId}-modal-source-section`);

    if (!modal) return;

    const showModal = () => {
      modal.style.display = 'flex';
      modal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    };

    const hideModal = () => {
      modal.style.display = 'none';
      modal.classList.add('hidden');
      document.body.style.overflow = '';
    };

    cells.forEach(cell => {
      cell.addEventListener('click', function() {
        const provider = this.getAttribute('data-provider');
        const vertical = this.getAttribute('data-vertical');
        const iconKey = this.getAttribute('data-icon');
        const play = this.getAttribute('data-play');
        const risk = this.getAttribute('data-risk');
        const date = this.getAttribute('data-date');
        const details = this.getAttribute('data-details');
        const source = this.getAttribute('data-source');

        // Update modal content
        if (modalProvider) modalProvider.textContent = provider;
        if (modalVertical) modalVertical.textContent = vertical;
        if (modalIcon && icons[iconKey]) {
          modalIcon.innerHTML = icons[iconKey].replace('w-6 h-6', 'w-8 h-8');
        }
        if (modalPlay) modalPlay.textContent = play;
        if (modalDate) modalDate.textContent = date ? `(${date})` : '';
        if (modalDetails) modalDetails.textContent = details;
        if (modalRisk) modalRisk.textContent = risk;

        // Show/hide source section based on availability
        if (source && source.trim()) {
          if (modalSource) modalSource.textContent = source;
          if (modalSourceSection) modalSourceSection.classList.remove('hidden');
        } else {
          if (modalSourceSection) modalSourceSection.classList.add('hidden');
        }

        showModal();
      });
    });

    // Close modal handlers
    if (modalClose) {
      modalClose.addEventListener('click', hideModal);
    }

    // Close on backdrop click
    modal.addEventListener('click', function(e) {
      if (e.target === modal) {
        hideModal();
      }
    });

    // Close on Escape key
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && modal.style.display === 'flex') {
        hideModal();
      }
    });
  })();
</script>


---
import CardCarousel from './CardCarousel.astro';

export interface Gateway {
  name: string;
  language: string;
  openSource: string;
  strength: string;
  gap: string;
  highlight?: boolean;
}

export interface Props {
  title?: string;
  subtitle?: string;
  gateways: Gateway[];
}

const { title, subtitle, gateways } = Astro.props;
---

<CardCarousel title={title} subtitle={subtitle} ariaLabel="LLM gateway landscape">
  {gateways.map((g) => (
    <article class="px-3 py-3 sm:px-5 sm:py-4">
      <div class={`relative rounded-xl overflow-hidden ring-1 ${
        g.highlight
          ? 'bg-gradient-to-br from-purple-50 to-fuchsia-50/30 dark:from-purple-900/30 dark:to-fuchsia-900/10 ring-purple-300 dark:ring-purple-600/50'
          : 'bg-gray-50/40 dark:bg-gray-900/40 ring-gray-200/60 dark:ring-gray-700/50'
      }`}>

        {/* Header bar — name + lang/license chips + optional ribbon */}
        <header class={`px-5 py-3 border-b ${
          g.highlight
            ? 'border-purple-200/60 dark:border-purple-700/40 bg-gradient-to-r from-purple-100/40 to-transparent dark:from-purple-800/20'
            : 'border-gray-200/60 dark:border-gray-700/40 bg-white/60 dark:bg-gray-900/30'
        }`}>
          <div class="flex items-baseline justify-between gap-3 flex-wrap">
            <div class="flex items-baseline gap-2.5 flex-wrap">
              <h5 class={`text-xl sm:text-2xl font-bold leading-tight ${
                g.highlight ? 'text-purple-700 dark:text-purple-300' : 'text-gray-900 dark:text-white'
              }`}>
                {g.name}
              </h5>
              <span class="inline-flex items-center text-[10px] font-mono uppercase tracking-wider px-1.5 py-0.5 rounded bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300">
                {g.language}
              </span>
              <span class={`inline-flex items-center text-[10px] font-mono uppercase tracking-wider px-1.5 py-0.5 rounded ${
                g.openSource.toLowerCase().startsWith('y') || g.openSource.toLowerCase().includes('apache') || g.openSource.toLowerCase().includes('mit')
                  ? 'bg-emerald-100 dark:bg-emerald-900/40 text-emerald-700 dark:text-emerald-300'
                  : 'bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400'
              }`}>
                {g.openSource}
              </span>
            </div>
            {g.highlight && (
              <span class="flex-shrink-0 text-[9px] font-bold uppercase tracking-widest px-1.5 py-0.5 rounded bg-gradient-to-br from-purple-500 to-fuchsia-500 text-white shadow-sm shadow-purple-500/30">
                This post
              </span>
            )}
          </div>
        </header>

        {/* Body — vertical stack of two labeled blocks */}
        <div class="divide-y divide-gray-200/60 dark:divide-gray-700/40">
          <div class="px-5 py-4">
            <div class="flex items-start gap-3">
              <span class={`mt-1 inline-flex items-center justify-center w-5 h-5 rounded-full text-[10px] font-bold flex-shrink-0 ${
                g.highlight
                  ? 'bg-gradient-to-br from-purple-500 to-fuchsia-500 text-white'
                  : 'bg-emerald-100 dark:bg-emerald-900/40 text-emerald-700 dark:text-emerald-300'
              }`} aria-hidden="true">+</span>
              <div class="min-w-0">
                <div class="text-[10px] uppercase tracking-wider font-bold text-gray-500 dark:text-gray-500 mb-0.5">
                  Strength
                </div>
                <p class="text-sm sm:text-base text-gray-800 dark:text-gray-100 leading-snug">{g.strength}</p>
              </div>
            </div>
          </div>

          <div class="px-5 py-4">
            <div class="flex items-start gap-3">
              <span class="mt-1 inline-flex items-center justify-center w-5 h-5 rounded-full text-[10px] font-bold flex-shrink-0 bg-amber-100 dark:bg-amber-900/40 text-amber-700 dark:text-amber-300" aria-hidden="true">!</span>
              <div class="min-w-0">
                <div class="text-[10px] uppercase tracking-wider font-bold text-gray-500 dark:text-gray-500 mb-0.5">
                  Gap for agents
                </div>
                <p class="text-sm text-gray-600 dark:text-gray-400 leading-snug">{g.gap}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </article>
  ))}
</CardCarousel>

---
export interface Strategy {
  strategy: string;
  reason: string;
  funnyTruth: string;
  icon?: string;
}

export interface Props {
  title: string;
  subtitle?: string;
  strategies: Strategy[];
}

const { title, subtitle, strategies } = Astro.props;

const defaultIcons = ['💬', '🎬', '🤝', '📝', '✅'];
---

<div class="strategy-table-container my-10">
  <!-- Header -->
  <div class="mb-6">
    <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2 flex items-center gap-3">
      <div class="w-1.5 h-8 bg-gradient-to-b from-sky-500 to-blue-600 rounded-full"></div>
      {title}
    </h3>
    {subtitle && <p class="text-gray-600 dark:text-gray-400 text-sm ml-5">{subtitle}</p>}
  </div>

  <!-- Table -->
  <div class="overflow-hidden rounded-2xl border border-gray-200 dark:border-gray-700 shadow-sm">
    <table class="w-full">
      <thead>
        <tr class="bg-gradient-to-r from-sky-500 to-blue-600 text-white">
          <th class="px-6 py-4 text-left text-sm font-semibold w-1/4">Strategy</th>
          <th class="px-6 py-4 text-left text-sm font-semibold w-1/3">Why It Works</th>
          <th class="px-6 py-4 text-left text-sm font-semibold w-5/12">
            <span class="flex items-center gap-2">
              <span>The Funny Truth</span>
              <span class="text-lg">😏</span>
            </span>
          </th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
        {strategies.map((item, index) => (
          <tr class="strategy-row bg-white dark:bg-gray-900 hover:bg-sky-50/50 dark:hover:bg-sky-950/20 transition-colors">
            <td class="px-6 py-5">
              <div class="flex items-start gap-3">
                <span class="text-2xl flex-shrink-0">{item.icon || defaultIcons[index % defaultIcons.length]}</span>
                <span class="font-semibold text-gray-900 dark:text-white text-sm leading-tight">
                  {item.strategy}
                </span>
              </div>
            </td>
            <td class="px-6 py-5">
              <p class="text-sm text-gray-600 dark:text-gray-300 leading-relaxed">
                {item.reason}
              </p>
            </td>
            <td class="px-6 py-5">
              <div class="relative">
                <div class="absolute -left-3 top-0 bottom-0 w-1 bg-gradient-to-b from-amber-400 to-orange-500 rounded-full"></div>
                <p class="text-sm text-gray-700 dark:text-gray-200 leading-relaxed italic pl-2">
                  "{item.funnyTruth}"
                </p>
              </div>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <!-- Footer Note -->
  <div class="mt-4 flex items-center gap-2 text-xs text-gray-500 dark:text-gray-400">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
    </svg>
    <span>Strategies derived from analysis of the open-sourced X algorithm codebase</span>
  </div>
</div>

<style>
  .strategy-row {
    transition: all 0.2s ease;
  }

  .strategy-row:hover {
    transform: scale(1.005);
  }

  /* Responsive table */
  @media (max-width: 768px) {
    .strategy-table-container table {
      display: block;
    }

    .strategy-table-container thead {
      display: none;
    }

    .strategy-table-container tbody {
      display: block;
    }

    .strategy-table-container tr {
      display: block;
      padding: 1rem;
      margin-bottom: 1rem;
      border-radius: 1rem;
      border: 1px solid;
      @apply border-gray-200 dark:border-gray-700;
    }

    .strategy-table-container td {
      display: block;
      padding: 0.75rem 0;
      border: none !important;
    }

    .strategy-table-container td:first-child {
      padding-bottom: 0.5rem;
      border-bottom: 1px solid;
      @apply border-gray-100 dark:border-gray-800;
    }

    .strategy-table-container td:nth-child(2)::before {
      content: 'Why It Works:';
      display: block;
      font-weight: 600;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 0.25rem;
      @apply text-sky-600 dark:text-sky-400;
    }

    .strategy-table-container td:nth-child(3)::before {
      content: 'The Funny Truth:';
      display: block;
      font-weight: 600;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 0.25rem;
      @apply text-amber-600 dark:text-amber-400;
    }
  }
</style>

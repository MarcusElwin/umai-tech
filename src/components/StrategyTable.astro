---
/**
 * StrategyTable - Styled table for displaying strategies with explanations
 *
 * Follows Umai design system:
 * - Primary color: Umai Purple (#8B5CF6)
 * - Consistent SVG icons
 * - Unified card patterns with gradients
 * - Responsive design with dark mode
 */

export interface Strategy {
  strategy: string;
  reason: string;
  funnyTruth: string;
  iconType?: 'reply' | 'media' | 'engage' | 'write' | 'verified';
}

export interface Props {
  title: string;
  subtitle?: string;
  strategies: Strategy[];
}

const { title, subtitle, strategies } = Astro.props;

const strategyIcons = {
  reply: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>`,
  media: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>`,
  engage: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>`,
  write: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>`,
  verified: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>`
};

const defaultIconOrder: (keyof typeof strategyIcons)[] = ['reply', 'media', 'engage', 'write', 'verified'];
---

<div class="strategy-table-container my-10">
  <!-- Header -->
  <div class="mb-6">
    <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2 flex items-center gap-3">
      <div class="w-1.5 h-8 bg-gradient-to-b from-[#8B5CF6] to-[#6366f1] rounded-full"></div>
      {title}
    </h3>
    {subtitle && <p class="text-gray-600 dark:text-gray-400 text-sm ml-5">{subtitle}</p>}
  </div>

  <!-- Table -->
  <div class="overflow-hidden rounded-2xl border border-gray-200 dark:border-gray-700 shadow-sm">
    <table class="w-full">
      <thead>
        <tr class="bg-gradient-to-r from-[#8B5CF6] to-[#6366f1] text-white">
          <th class="px-6 py-4 text-left text-sm font-semibold w-1/4">Strategy</th>
          <th class="px-6 py-4 text-left text-sm font-semibold w-1/3">Why It Works</th>
          <th class="px-6 py-4 text-left text-sm font-semibold w-5/12">
            <span class="flex items-center gap-2">
              <span>The Funny Truth</span>
              <svg class="w-4 h-4 text-white/70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </span>
          </th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
        {strategies.map((item, index) => {
          const iconKey = item.iconType || defaultIconOrder[index % defaultIconOrder.length];
          return (
            <tr class="strategy-row bg-white dark:bg-gray-900 hover:bg-purple-50/50 dark:hover:bg-purple-950/20 transition-colors">
              <td class="px-6 py-5">
                <div class="flex items-start gap-3">
                  <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-gradient-to-br from-[#8B5CF6]/20 to-[#6366f1]/20 dark:from-[#8B5CF6]/30 dark:to-[#6366f1]/30 border border-[#8B5CF6]/30 flex items-center justify-center text-[#8B5CF6]">
                    <Fragment set:html={strategyIcons[iconKey]} />
                  </div>
                  <span class="font-semibold text-gray-900 dark:text-white text-sm leading-tight pt-2">
                    {item.strategy}
                  </span>
                </div>
              </td>
              <td class="px-6 py-5">
                <p class="text-sm text-gray-600 dark:text-gray-300 leading-relaxed">
                  {item.reason}
                </p>
              </td>
              <td class="px-6 py-5">
                <div class="relative">
                  <div class="absolute -left-3 top-0 bottom-0 w-1 bg-gradient-to-b from-amber-400 to-orange-500 rounded-full"></div>
                  <p class="text-sm text-gray-700 dark:text-gray-200 leading-relaxed italic pl-2">
                    "{item.funnyTruth}"
                  </p>
                </div>
              </td>
            </tr>
          );
        })}
      </tbody>
    </table>
  </div>

  <!-- Footer Note -->
  <div class="mt-4 flex items-center gap-2 text-xs text-gray-500 dark:text-gray-400">
    <svg class="w-4 h-4 text-[#8B5CF6]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
    </svg>
    <span>Strategies derived from analysis of the open-sourced X algorithm codebase</span>
  </div>
</div>

<style>
  .strategy-row {
    transition: all 0.2s ease;
  }

  .strategy-row:hover {
    transform: scale(1.002);
  }

  /* Responsive table */
  @media (max-width: 768px) {
    .strategy-table-container table {
      display: block;
    }

    .strategy-table-container thead {
      display: none;
    }

    .strategy-table-container tbody {
      display: block;
    }

    .strategy-table-container tr {
      display: block;
      padding: 1rem;
      margin-bottom: 1rem;
      border-radius: 1rem;
      border: 1px solid;
      @apply border-gray-200 dark:border-gray-700;
    }

    .strategy-table-container td {
      display: block;
      padding: 0.75rem 0;
      border: none !important;
    }

    .strategy-table-container td:first-child {
      padding-bottom: 0.5rem;
      border-bottom: 1px solid;
      @apply border-gray-100 dark:border-gray-800;
    }

    .strategy-table-container td:nth-child(2)::before {
      content: 'Why It Works:';
      display: block;
      font-weight: 600;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 0.25rem;
      color: #8B5CF6;
    }

    .strategy-table-container td:nth-child(3)::before {
      content: 'The Funny Truth:';
      display: block;
      font-weight: 600;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 0.25rem;
      @apply text-amber-600 dark:text-amber-400;
    }
  }
</style>

---
export interface NetworkEffect {
  label: string;
  description: string;
}

export interface Props {
  stages: Array<{
    label: string;
    description: string;
    icon?: string;
  }>;
  title?: string;
  subtitle?: string;
  networkEffects?: NetworkEffect[];
  networkEffectsLabel?: string;
}

const { stages, title = 'The Data Flywheel', subtitle, networkEffects, networkEffectsLabel = 'Network effects on top' } = Astro.props;
const componentId = `flywheel-${Math.random().toString(36).slice(2, 11)}`;

const defaultIcons: Record<string, string> = {
  usage: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>`,
  data: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"/></svg>`,
  model: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>`,
  product: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`,
  retention: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>`,
};

const stageColors = [
  { bg: 'from-purple-500 to-purple-600', text: 'text-white', ring: 'ring-purple-400/30', glow: 'shadow-purple-500/20' },
  { bg: 'from-violet-500 to-violet-600', text: 'text-white', ring: 'ring-violet-400/30', glow: 'shadow-violet-500/20' },
  { bg: 'from-indigo-500 to-indigo-600', text: 'text-white', ring: 'ring-indigo-400/30', glow: 'shadow-indigo-500/20' },
  { bg: 'from-blue-500 to-blue-600', text: 'text-white', ring: 'ring-blue-400/30', glow: 'shadow-blue-500/20' },
  { bg: 'from-cyan-500 to-cyan-600', text: 'text-white', ring: 'ring-cyan-400/30', glow: 'shadow-cyan-500/20' },
];
---

<div class="flywheel-wrapper my-10 flywheel-network-on" id={componentId}>
  {/* Header */}
  <div class="text-center mb-6">
    <h4 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">{title}</h4>
    {subtitle && <p class="text-sm text-gray-500 dark:text-gray-400 max-w-xl mx-auto">{subtitle}</p>}
  </div>

  {/* Toggle — only renders when network effects are passed */}
  {networkEffects && networkEffects.length > 0 && (
    <div class="flex justify-center mb-6">
      <button
        type="button"
        class="flywheel-toggle group inline-flex items-center gap-3 rounded-full border border-pink-200 dark:border-pink-700/50 bg-white/80 dark:bg-gray-800/60 px-4 py-1.5 text-xs font-semibold text-gray-700 dark:text-gray-200 hover:border-pink-300 dark:hover:border-pink-600 transition-colors shadow-sm"
        data-flywheel-toggle={componentId}
        aria-pressed="true"
        aria-label="Toggle network effects ring"
      >
        <span class="inline-block w-2.5 h-2.5 rounded-full bg-gradient-to-br from-pink-400 to-fuchsia-500 flywheel-toggle-dot transition-all"></span>
        <span class="flywheel-toggle-label">Network effects: <span class="text-pink-600 dark:text-pink-300 font-bold flywheel-toggle-state">on</span></span>
      </button>
    </div>
  )}

  {/* Flywheel Visual — wider when network effects are present so satellites have room */}
  <div class={`relative mx-auto ${networkEffects && networkEffects.length ? 'max-w-2xl' : 'max-w-lg'}`}>
    {/* Center hub */}
    <div class="flywheel-hub absolute inset-0 flex items-center justify-center pointer-events-none z-10">
      <div class="w-20 h-20 rounded-full bg-gradient-to-br from-purple-600 to-indigo-600 dark:from-purple-500 dark:to-indigo-500 shadow-lg shadow-purple-500/30 flex items-center justify-center">
        <svg class="w-8 h-8 text-white flywheel-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
        </svg>
      </div>
    </div>

    {/* SVG with inner flywheel ring + optional outer network-effect ring */}
    <svg class="w-full" viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <marker id={`${componentId}-arrow`} markerWidth="8" markerHeight="6" refX="8" refY="3" orient="auto">
          <path d="M0 0 L8 3 L0 6 Z" fill="#8B5CF6" opacity="0.6"/>
        </marker>
        <linearGradient id={`${componentId}-grad`} x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="#8B5CF6" />
          <stop offset="100%" stop-color="#6366F1" stop-opacity="0.3" />
        </linearGradient>
        <linearGradient id={`${componentId}-grad-outer`} x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="#F472B6" stop-opacity="0.7" />
          <stop offset="100%" stop-color="#8B5CF6" stop-opacity="0.4" />
        </linearGradient>
      </defs>

      {/* Inner flywheel ring */}
      <circle cx="200" cy="200" r="120" stroke="#8B5CF6" stroke-width="2" stroke-dasharray="12 6" opacity="0.25" fill="none" />
      <circle cx="200" cy="200" r="120" stroke={`url(#${componentId}-grad)`} stroke-width="3" stroke-dasharray="60 700" fill="none" class="flywheel-ring" />

      {/* Outer network-effects ring + connector spokes — only when networkEffects are passed */}
      {networkEffects && networkEffects.length > 0 && (
        <g class="flywheel-outer-svg">
          {/* Static dashed outer ring */}
          <circle cx="200" cy="200" r="180" stroke="#F472B6" stroke-width="1.5" stroke-dasharray="4 6" opacity="0.35" fill="none" />
          {/* Animated arc — counter-rotates against the inner ring */}
          <circle cx="200" cy="200" r="180" stroke={`url(#${componentId}-grad-outer)`} stroke-width="2.5" stroke-dasharray="80 1050" fill="none" class="flywheel-outer-ring" />

          {networkEffects.map((_, i) => {
            const total = networkEffects.length;
            // Offset outer satellites between inner stages (rotate by half a stage gap)
            const angle = (i / total) * 2 * Math.PI - Math.PI / 2 + Math.PI / total;
            const x1 = 200 + 130 * Math.cos(angle);
            const y1 = 200 + 130 * Math.sin(angle);
            const x2 = 200 + 170 * Math.cos(angle);
            const y2 = 200 + 170 * Math.sin(angle);
            return (
              <g>
                <line
                  x1={x1}
                  y1={y1}
                  x2={x2}
                  y2={y2}
                  stroke="#F472B6"
                  stroke-width="1.5"
                  stroke-dasharray="3 3"
                  opacity="0.6"
                  class="flywheel-spoke"
                  style={`animation-delay: ${0.6 + i * 0.15}s`}
                  marker-end={`url(#${componentId}-arrow)`}
                />
                {/* Traveling signal dot — animates from satellite toward inner ring on a loop */}
                <circle
                  r="4"
                  fill="#EC4899"
                  opacity="0.85"
                  class="flywheel-signal-dot"
                  style={`offset-path: path('M ${x2} ${y2} L ${x1} ${y1}'); animation-delay: ${i * 0.9}s;`}
                />
              </g>
            );
          })}
        </g>
      )}
    </svg>

    {/* Inner stage nodes positioned around the inner ring */}
    <div class="absolute inset-0">
      {stages.map((stage, i) => {
        const total = stages.length;
        const angle = (i / total) * 2 * Math.PI - Math.PI / 2;
        const radius = networkEffects && networkEffects.length ? 34 : 42;
        const x = 50 + radius * Math.cos(angle);
        const y = 50 + radius * Math.sin(angle);
        const color = stageColors[i % stageColors.length];

        return (
          <div
            class="flywheel-node absolute -translate-x-1/2 -translate-y-1/2"
            style={`left: ${x}%; top: ${y}%;`}
            data-index={i}
          >
            <button
              class={`group relative flex flex-col items-center gap-1 cursor-pointer`}
              data-flywheel-btn={componentId}
              data-stage={i}
              aria-label={`Stage ${i + 1}: ${stage.label}`}
            >
              <div class={`w-12 h-12 rounded-full bg-gradient-to-br ${color.bg} ${color.text} flex items-center justify-center shadow-lg ${color.glow} ring-2 ${color.ring} transition-all duration-300 group-hover:scale-110 group-hover:shadow-xl`}>
                <span class="text-sm font-bold">{i + 1}</span>
              </div>
              <span class="text-xs font-medium text-gray-700 dark:text-gray-300 whitespace-nowrap max-w-[90px] text-center leading-tight">{stage.label}</span>
            </button>
          </div>
        );
      })}
    </div>

    {/* Outer network-effect satellites — only when networkEffects are passed */}
    {networkEffects && networkEffects.length > 0 && (
      <div class="absolute inset-0 flywheel-outer-nodes">
        {networkEffects.map((effect, i) => {
          const total = networkEffects.length;
          const angle = (i / total) * 2 * Math.PI - Math.PI / 2 + Math.PI / total;
          const radius = 48;
          const x = 50 + radius * Math.cos(angle);
          const y = 50 + radius * Math.sin(angle);
          return (
            <div
              class="flywheel-network-node absolute -translate-x-1/2 -translate-y-1/2"
              style={`left: ${x}%; top: ${y}%;`}
              data-index={i}
            >
              <button
                class="group flex flex-col items-center gap-1 cursor-pointer"
                data-flywheel-network-btn={componentId}
                data-network={i}
                aria-label={`Network effect ${i + 1}: ${effect.label}`}
              >
                <div class="w-9 h-9 rounded-full bg-gradient-to-br from-pink-400 to-fuchsia-500 dark:from-pink-500 dark:to-fuchsia-600 text-white flex items-center justify-center shadow-md shadow-pink-500/30 ring-2 ring-pink-300/40 dark:ring-pink-500/30 transition-all duration-300 group-hover:scale-110 group-hover:shadow-lg">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87m6-3a4 4 0 100-8 4 4 0 000 8zm6 0a3 3 0 100-6 3 3 0 000 6zm-12 0a3 3 0 100-6 3 3 0 000 6z"/>
                  </svg>
                </div>
                <span class="text-[11px] font-semibold text-pink-600 dark:text-pink-300 whitespace-nowrap max-w-[110px] text-center leading-tight">{effect.label}</span>
              </button>
            </div>
          );
        })}
      </div>
    )}
  </div>

  {/* Legend — shows when network effects are present */}
  {networkEffects && networkEffects.length > 0 && (
    <div class="mt-4 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-xs text-gray-600 dark:text-gray-400">
      <div class="flex items-center gap-2">
        <span class="inline-block w-3 h-3 rounded-full bg-gradient-to-br from-purple-500 to-indigo-600"></span>
        <span><strong class="text-gray-800 dark:text-gray-200">Inner loop</strong> — what feeds the flywheel</span>
      </div>
      <div class="flex items-center gap-2 flywheel-outer-legend">
        <span class="inline-block w-3 h-3 rounded-full bg-gradient-to-br from-pink-400 to-fuchsia-500"></span>
        <span><strong class="text-gray-800 dark:text-gray-200">{networkEffectsLabel}</strong> — what compounds at scale</span>
      </div>
    </div>
  )}

  {/* Description panel */}
  <div class="mt-6 min-h-[80px]" id={`${componentId}-desc`}>
    <div class="rounded-lg border border-gray-200/60 dark:border-gray-700/40 bg-white/80 dark:bg-gray-800/40 p-4 text-center transition-all duration-300">
      <p class="text-sm text-gray-500 dark:text-gray-400 italic">Click a stage to see details</p>
    </div>
  </div>

  {/* Linear fallback for small screens */}
  <div class="flywheel-linear hidden mt-6">
    <div class="text-[10px] font-bold uppercase tracking-wider text-purple-600 dark:text-purple-300 mb-2">Inner loop</div>
    {stages.map((stage, i) => {
      const color = stageColors[i % stageColors.length];
      return (
        <div class="flex items-start gap-3 mb-4 last:mb-0">
          <div class={`flex-shrink-0 w-8 h-8 rounded-full bg-gradient-to-br ${color.bg} ${color.text} flex items-center justify-center text-xs font-bold shadow-md`}>
            {i + 1}
          </div>
          <div class="flex-1 min-w-0">
            <p class="font-medium text-gray-900 dark:text-gray-100 text-sm">{stage.label}</p>
            <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">{stage.description}</p>
          </div>
          {i < stages.length - 1 && (
            <div class="flex-shrink-0 self-center text-purple-400">
              <svg class="w-4 h-4 rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
              </svg>
            </div>
          )}
        </div>
      );
    })}

    {networkEffects && networkEffects.length > 0 && (
      <div class="flywheel-outer-linear">
        <div class="text-[10px] font-bold uppercase tracking-wider text-pink-600 dark:text-pink-300 mt-6 mb-2">{networkEffectsLabel}</div>
        {networkEffects.map((effect) => (
          <div class="flex items-start gap-3 mb-3 last:mb-0">
            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-gradient-to-br from-pink-400 to-fuchsia-500 text-white flex items-center justify-center shadow-md">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87m6-3a4 4 0 100-8 4 4 0 000 8zm6 0a3 3 0 100-6 3 3 0 000 6zm-12 0a3 3 0 100-6 3 3 0 000 6z"/>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <p class="font-medium text-gray-900 dark:text-gray-100 text-sm">{effect.label}</p>
              <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">{effect.description}</p>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</div>

<script define:vars={{ componentId, stages, networkEffects }} is:inline>
  function initFlywheel() {
    const wrapper = document.getElementById(componentId);
    if (!wrapper) { setTimeout(initFlywheel, 100); return; }

    const descPanel = document.getElementById(`${componentId}-desc`);
    const innerBtns = wrapper.querySelectorAll(`[data-flywheel-btn="${componentId}"]`);
    const outerBtns = wrapper.querySelectorAll(`[data-flywheel-network-btn="${componentId}"]`);

    function clearActive() {
      [...innerBtns, ...outerBtns].forEach(b => {
        const circle = b.querySelector('div');
        if (circle) circle.classList.remove('scale-110', 'shadow-xl');
      });
    }

    function updateDesc(label, description, kind) {
      if (!descPanel) return;
      const accent = kind === 'network'
        ? 'border-pink-200/60 dark:border-pink-700/40 bg-pink-50/50 dark:bg-pink-900/20'
        : 'border-purple-200/60 dark:border-purple-700/40 bg-purple-50/50 dark:bg-purple-900/20';
      const tag = kind === 'network'
        ? '<span class="inline-block text-[10px] font-bold uppercase tracking-wider text-pink-600 dark:text-pink-300 mb-1">Network effect</span>'
        : '<span class="inline-block text-[10px] font-bold uppercase tracking-wider text-purple-600 dark:text-purple-300 mb-1">Inner loop</span>';
      descPanel.innerHTML = `
        <div class="rounded-lg border ${accent} p-4 text-center transition-all duration-300">
          ${tag}
          <p class="font-semibold text-gray-900 dark:text-gray-100 text-base mb-1">${label}</p>
          <p class="text-sm text-gray-600 dark:text-gray-300">${description}</p>
        </div>
      `;
    }

    innerBtns.forEach(btn => {
      btn.addEventListener('click', function() {
        const idx = parseInt(this.getAttribute('data-stage'));
        const stage = stages[idx];
        clearActive();
        const c = this.querySelector('div');
        if (c) c.classList.add('scale-110', 'shadow-xl');
        updateDesc(stage.label, stage.description, 'inner');
      });
    });

    outerBtns.forEach(btn => {
      btn.addEventListener('click', function() {
        const idx = parseInt(this.getAttribute('data-network'));
        const effect = networkEffects && networkEffects[idx];
        if (!effect) return;
        clearActive();
        const c = this.querySelector('div');
        if (c) c.classList.add('scale-110', 'shadow-xl');
        updateDesc(effect.label, effect.description, 'network');
      });
    });

    // Toggle network-effects ring on/off
    const toggle = wrapper.querySelector(`[data-flywheel-toggle="${componentId}"]`);
    if (toggle) {
      toggle.addEventListener('click', function() {
        const isOn = wrapper.classList.contains('flywheel-network-on');
        wrapper.classList.toggle('flywheel-network-on', !isOn);
        wrapper.classList.toggle('flywheel-network-off', isOn);
        this.setAttribute('aria-pressed', String(!isOn));
        const stateLabel = this.querySelector('.flywheel-toggle-state');
        if (stateLabel) stateLabel.textContent = isOn ? 'off' : 'on';
        // If turning off and an outer node is currently active, reset the description
        if (isOn && descPanel) {
          const activeOuter = wrapper.querySelector('.flywheel-network-node div.scale-110');
          if (activeOuter) {
            clearActive();
            descPanel.innerHTML = `
              <div class="rounded-lg border border-gray-200/60 dark:border-gray-700/40 bg-white/80 dark:bg-gray-800/40 p-4 text-center transition-all duration-300">
                <p class="text-sm text-gray-500 dark:text-gray-400 italic">Click a stage to see details</p>
              </div>
            `;
          }
        }
      });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFlywheel);
  } else {
    initFlywheel();
  }
</script>

<style>
  .flywheel-wrapper {
    position: relative;
  }

  .flywheel-spin {
    animation: spin 8s linear infinite;
  }

  .flywheel-ring {
    animation: ring-rotate 6s linear infinite;
    transform-origin: center;
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  @keyframes ring-rotate {
    from { stroke-dashoffset: 0; }
    to { stroke-dashoffset: -940; }
  }

  .flywheel-node {
    animation: fadeInUp 0.5s ease-out both;
  }

  .flywheel-node[data-index="0"] { animation-delay: 0.1s; }
  .flywheel-node[data-index="1"] { animation-delay: 0.2s; }
  .flywheel-node[data-index="2"] { animation-delay: 0.3s; }
  .flywheel-node[data-index="3"] { animation-delay: 0.4s; }
  .flywheel-node[data-index="4"] { animation-delay: 0.5s; }

  .flywheel-network-node {
    animation: fadeInUp 0.5s ease-out both;
  }
  .flywheel-network-node[data-index="0"] { animation-delay: 0.7s; }
  .flywheel-network-node[data-index="1"] { animation-delay: 0.85s; }
  .flywheel-network-node[data-index="2"] { animation-delay: 1s; }

  .flywheel-spoke {
    animation: spokeFade 0.6s ease-out both;
  }

  @keyframes spokeFade {
    from { opacity: 0; stroke-dashoffset: 20; }
    to { opacity: 0.6; stroke-dashoffset: 0; }
  }

  /* Outer ring — counter-rotates against the inner ring */
  .flywheel-outer-ring {
    animation: outer-ring-rotate 9s linear infinite;
    transform-origin: 200px 200px;
  }

  @keyframes outer-ring-rotate {
    from { stroke-dashoffset: 0; }
    to { stroke-dashoffset: 1130; } /* opposite sign vs inner = visually counter-rotating */
  }

  /* Traveling signal dot along each spoke, satellite → hub */
  .flywheel-signal-dot {
    offset-distance: 0%;
    animation: signal-flow 2.8s ease-in-out infinite;
  }

  @keyframes signal-flow {
    0%   { offset-distance: 0%;   opacity: 0; }
    10%  { opacity: 0.85; }
    85%  { opacity: 0.85; }
    100% { offset-distance: 100%; opacity: 0; }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translate(-50%, -50%) translateY(10px);
    }
    to {
      opacity: 1;
      transform: translate(-50%, -50%) translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .flywheel-spin,
    .flywheel-ring,
    .flywheel-outer-ring,
    .flywheel-signal-dot,
    .flywheel-spoke,
    .flywheel-node,
    .flywheel-network-node {
      animation: none;
    }
    .flywheel-signal-dot {
      opacity: 0;
    }
  }

  /* Toggle: hide the entire outer ring when network effects are off */
  .flywheel-wrapper.flywheel-network-off .flywheel-outer-svg,
  .flywheel-wrapper.flywheel-network-off .flywheel-outer-nodes,
  .flywheel-wrapper.flywheel-network-off .flywheel-outer-legend,
  .flywheel-wrapper.flywheel-network-off .flywheel-outer-linear {
    display: none;
  }

  /* Soften the toggle visual when off */
  .flywheel-wrapper.flywheel-network-off .flywheel-toggle-dot {
    background: #d1d5db;
    background-image: none;
  }
  .flywheel-wrapper.flywheel-network-off .flywheel-toggle {
    border-color: rgb(229 231 235 / 0.8);
  }
  .flywheel-wrapper.flywheel-network-off .flywheel-toggle-state {
    color: rgb(107 114 128);
  }

  /* Hide circular on very small screens, show linear */
  @media (max-width: 480px) {
    .flywheel-wrapper .relative.mx-auto,
    .flywheel-wrapper #flywheel-desc {
      display: none;
    }
    .flywheel-linear {
      display: block !important;
    }
  }
</style>

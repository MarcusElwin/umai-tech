---
export interface Case {
  company: string;
  model: string;
  released: string;
  modelDetails: string;
  moatLabel: string;
  moatStat: string;
  moatExplain: string;
  accent: 'amber' | 'purple' | 'rose' | 'blue' | 'emerald';
}

export interface Props {
  title?: string;
  subtitle?: string;
  cases: Case[];
  punchline?: string;
}

const { title, subtitle, cases, punchline } = Astro.props;

const accentMap: Record<string, { ring: string; dot: string; gradient: string; chip: string }> = {
  amber: {
    ring: 'ring-amber-200 dark:ring-amber-700/40',
    dot: 'bg-amber-500',
    gradient: 'from-amber-50 to-orange-50/30 dark:from-amber-900/15 dark:to-orange-900/5',
    chip: 'bg-amber-100 text-amber-700 dark:bg-amber-900/40 dark:text-amber-300',
  },
  purple: {
    ring: 'ring-purple-200 dark:ring-purple-700/40',
    dot: 'bg-purple-500',
    gradient: 'from-purple-50 to-fuchsia-50/30 dark:from-purple-900/15 dark:to-fuchsia-900/5',
    chip: 'bg-purple-100 text-purple-700 dark:bg-purple-900/40 dark:text-purple-300',
  },
  rose: {
    ring: 'ring-rose-200 dark:ring-rose-700/40',
    dot: 'bg-rose-500',
    gradient: 'from-rose-50 to-pink-50/30 dark:from-rose-900/15 dark:to-pink-900/5',
    chip: 'bg-rose-100 text-rose-700 dark:bg-rose-900/40 dark:text-rose-300',
  },
  blue: {
    ring: 'ring-blue-200 dark:ring-blue-700/40',
    dot: 'bg-blue-500',
    gradient: 'from-blue-50 to-cyan-50/30 dark:from-blue-900/15 dark:to-cyan-900/5',
    chip: 'bg-blue-100 text-blue-700 dark:bg-blue-900/40 dark:text-blue-300',
  },
  emerald: {
    ring: 'ring-emerald-200 dark:ring-emerald-700/40',
    dot: 'bg-emerald-500',
    gradient: 'from-emerald-50 to-teal-50/30 dark:from-emerald-900/15 dark:to-teal-900/5',
    chip: 'bg-emerald-100 text-emerald-700 dark:bg-emerald-900/40 dark:text-emerald-300',
  },
};
---

<div class="foundation-moat my-10">
  {(title || subtitle) && (
    <div class="mb-6">
      {title && <h4 class="text-xl font-semibold text-gray-900 dark:text-white mb-1">{title}</h4>}
      {subtitle && <p class="text-sm text-gray-600 dark:text-gray-400">{subtitle}</p>}
    </div>
  )}

  <div class="grid md:grid-cols-3 gap-4">
    {cases.map((c) => {
      const a = accentMap[c.accent] || accentMap.purple;
      return (
        <div class={`fm-card rounded-2xl bg-gradient-to-br ${a.gradient} ring-1 ${a.ring} p-5 flex flex-col`}>
          {/* Header: company + release date */}
          <div class="flex items-baseline justify-between mb-2">
            <h5 class="text-base font-bold text-gray-900 dark:text-white">{c.company}</h5>
            <span class="text-[10px] uppercase tracking-wider font-semibold text-gray-500 dark:text-gray-500">{c.released}</span>
          </div>

          {/* Model name + details */}
          <div class="mb-4">
            <div class="flex items-center gap-2 mb-1.5">
              <span class={`inline-block w-1.5 h-1.5 rounded-full ${a.dot}`} aria-hidden="true"></span>
              <span class={`text-[11px] font-bold uppercase tracking-wider px-1.5 py-0.5 rounded ${a.chip}`}>The model</span>
            </div>
            <p class="text-sm font-semibold text-gray-900 dark:text-gray-100 mb-1">{c.model}</p>
            <p class="text-xs text-gray-600 dark:text-gray-400 leading-snug">{c.modelDetails}</p>
          </div>

          {/* The actual moat */}
          <div class="mt-auto pt-4 border-t border-gray-200/60 dark:border-gray-700/40">
            <div class="text-[10px] uppercase tracking-wider font-bold text-gray-500 dark:text-gray-400 mb-1.5">
              The real moat
            </div>
            <div class="text-base font-bold text-gray-900 dark:text-white mb-1">{c.moatStat}</div>
            <div class="text-xs font-semibold text-gray-700 dark:text-gray-300 mb-1.5">{c.moatLabel}</div>
            <p class="text-xs text-gray-600 dark:text-gray-400 leading-snug">{c.moatExplain}</p>
          </div>
        </div>
      );
    })}
  </div>

  {punchline && (
    <p class="mt-5 text-sm text-gray-700 dark:text-gray-300 italic leading-relaxed">
      {punchline}
    </p>
  )}
</div>

<style>
  .foundation-moat .fm-card {
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .foundation-moat .fm-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -8px rgba(0, 0, 0, 0.08);
  }
  @media (prefers-reduced-motion: reduce) {
    .foundation-moat .fm-card {
      transition: none;
    }
    .foundation-moat .fm-card:hover {
      transform: none;
    }
  }
</style>

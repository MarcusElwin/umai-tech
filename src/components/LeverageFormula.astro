---
export interface Props {
  contextSources?: string[];
  aiCapabilities?: string[];
}

const {
  contextSources = [
    "Historical Decisions",
    "Political Landscape",
    "Technical Debt Map",
    "Strategic Priorities"
  ],
  aiCapabilities = [
    "Code Generation",
    "Pattern Recognition",
    "Rapid Prototyping"
  ]
} = Astro.props;
---

<div class="leverage-formula my-10">
  <div class="bg-gradient-to-br from-umai-gray-50 to-white dark:from-umai-gray-800 dark:to-umai-gray-700 rounded-xl border border-umai-gray-200 dark:border-umai-gray-600 overflow-hidden">
    {/* Header */}
    <div class="p-6 border-b border-umai-gray-200 dark:border-umai-gray-600">
      <h4 class="text-xl font-bold text-gray-900 dark:text-white mb-2">The Player-Coach Leverage Formula</h4>
      <p class="text-gray-600 dark:text-gray-400 text-sm">Why context-rich leaders get disproportionate returns from AI tools</p>
    </div>

    {/* Formula Visualization */}
    <div class="p-6">
      <div class="flex flex-col lg:flex-row items-center justify-center gap-4 lg:gap-6">
        {/* Deep Context */}
        <div class="formula-card w-full lg:w-auto">
          <div class="bg-gradient-to-br from-blue-50 to-blue-100 dark:from-blue-950/50 dark:to-blue-900/30 border-2 border-blue-300 dark:border-blue-700 rounded-xl p-5 min-w-[200px]">
            <div class="flex items-center gap-2 mb-3">
              <div class="w-8 h-8 rounded-lg bg-blue-600 flex items-center justify-center">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
              </div>
              <h5 class="font-bold text-blue-800 dark:text-blue-200">Deep Context</h5>
            </div>
            <div class="space-y-2">
              {contextSources.map((source) => (
                <div class="flex items-center gap-2 text-xs">
                  <div class="w-1.5 h-1.5 rounded-full bg-blue-500"></div>
                  <span class="text-blue-700 dark:text-blue-300">{source}</span>
                </div>
              ))}
            </div>
          </div>
        </div>

        {/* Plus Sign */}
        <div class="text-3xl font-bold text-gray-400 dark:text-gray-500">+</div>

        {/* AI Fluency */}
        <div class="formula-card w-full lg:w-auto">
          <div class="bg-gradient-to-br from-purple-50 to-purple-100 dark:from-purple-950/50 dark:to-purple-900/30 border-2 border-purple-300 dark:border-purple-700 rounded-xl p-5 min-w-[200px]">
            <div class="flex items-center gap-2 mb-3">
              <div class="w-8 h-8 rounded-lg bg-purple-600 flex items-center justify-center">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <h5 class="font-bold text-purple-800 dark:text-purple-200">AI Fluency</h5>
            </div>
            <div class="space-y-2">
              {aiCapabilities.map((capability) => (
                <div class="flex items-center gap-2 text-xs">
                  <div class="w-1.5 h-1.5 rounded-full bg-purple-500"></div>
                  <span class="text-purple-700 dark:text-purple-300">{capability}</span>
                </div>
              ))}
            </div>
          </div>
        </div>

        {/* Equals Sign */}
        <div class="text-3xl font-bold text-gray-400 dark:text-gray-500">=</div>

        {/* Result */}
        <div class="formula-card w-full lg:w-auto">
          <div class="bg-gradient-to-br from-green-50 to-green-100 dark:from-green-950/50 dark:to-green-900/30 border-2 border-green-400 dark:border-green-600 rounded-xl p-5 min-w-[200px] ring-4 ring-green-400/30 dark:ring-green-500/20 shadow-lg shadow-green-500/10">
            <div class="flex items-center gap-2 mb-3">
              <div class="w-8 h-8 rounded-lg bg-green-600 flex items-center justify-center">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                </svg>
              </div>
              <h5 class="font-bold text-green-800 dark:text-green-200">Player-Coach Leverage</h5>
            </div>
            <div class="space-y-2">
              <div class="flex items-center gap-2 text-xs">
                <div class="w-1.5 h-1.5 rounded-full bg-green-500"></div>
                <span class="text-green-700 dark:text-green-300">Strategic altitude maintained</span>
              </div>
              <div class="flex items-center gap-2 text-xs">
                <div class="w-1.5 h-1.5 rounded-full bg-green-500"></div>
                <span class="text-green-700 dark:text-green-300">Direct output at scale</span>
              </div>
              <div class="flex items-center gap-2 text-xs">
                <div class="w-1.5 h-1.5 rounded-full bg-green-500"></div>
                <span class="text-green-700 dark:text-green-300">Judgment-directed AI</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      {/* Arrows showing flow */}
      <div class="hidden lg:flex justify-center mt-6">
        <div class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <span>Context directs AI → AI amplifies context → Leverage compounds</span>
        </div>
      </div>
    </div>

    {/* Key Insight */}
    <div class="p-4 bg-gradient-to-r from-green-50 to-emerald-50 dark:from-green-950/30 dark:to-emerald-950/30 border-t border-green-200 dark:border-green-800">
      <div class="flex items-start gap-3">
        <svg class="w-5 h-5 text-green-600 dark:text-green-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
        </svg>
        <div class="text-sm">
          <p class="text-green-800 dark:text-green-200 font-medium mb-1">The Compounding Effect</p>
          <p class="text-green-700 dark:text-green-300 leading-relaxed">
            Pure ICs have AI fluency but often lack strategic context. Product Engineers have context but delegate implementation.
            The Player-Coach <strong>keeps both</strong>—and the combination creates leverage that neither can match alone.
          </p>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .leverage-formula {
    transition: all 0.3s ease;
  }

  .formula-card {
    transition: transform 0.2s ease;
  }

  .formula-card:hover {
    transform: translateY(-2px);
  }
</style>

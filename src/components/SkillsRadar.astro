---
export interface Skill {
  id: string;
  name: string;
  shortName: string;
  level: number; // 0-100
  description: string;
  developBy: string;
  icon: string;
  color: string;
}

export interface Props {
  skills: Skill[];
  title?: string;
  subtitle?: string;
}

const {
  skills,
  title = "Player-Coach Skill Radar",
  subtitle = "Click any skill to learn more"
} = Astro.props;

// Calculate positions for pentagon (5 skills)
const centerX = 150;
const centerY = 150;
const maxRadius = 120;

function getPosition(index: number, radius: number, total: number = 5) {
  const angle = (index * 2 * Math.PI / total) - Math.PI / 2; // Start from top
  return {
    x: centerX + radius * Math.cos(angle),
    y: centerY + radius * Math.sin(angle)
  };
}

// Generate polygon points for skill levels
function getPolygonPoints(skills: Skill[]) {
  return skills.map((skill, i) => {
    const radius = (skill.level / 100) * maxRadius;
    const pos = getPosition(i, radius, skills.length);
    return `${pos.x},${pos.y}`;
  }).join(' ');
}

// Generate grid lines
const gridLevels = [20, 40, 60, 80, 100];
---

<div class="skills-radar my-10">
  <div class="bg-gradient-to-br from-umai-gray-50 to-white dark:from-umai-gray-800 dark:to-umai-gray-700 rounded-xl border border-umai-gray-200 dark:border-umai-gray-600 overflow-hidden">
    {/* Header */}
    <div class="p-6 border-b border-umai-gray-200 dark:border-umai-gray-600">
      <h4 class="text-xl font-bold text-gray-900 dark:text-white mb-1">{title}</h4>
      <p class="text-gray-600 dark:text-gray-400 text-sm">{subtitle}</p>
    </div>

    <div class="p-6">
      <div class="flex flex-col lg:flex-row items-center gap-8">
        {/* Radar Chart */}
        <div class="relative flex-shrink-0">
          <svg width="300" height="300" class="radar-svg">
            {/* Grid circles */}
            {gridLevels.map((level) => {
              const radius = (level / 100) * maxRadius;
              const points = Array.from({ length: 5 }, (_, i) => {
                const pos = getPosition(i, radius);
                return `${pos.x},${pos.y}`;
              }).join(' ');
              return (
                <polygon
                  points={points}
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1"
                  class="text-gray-200 dark:text-gray-700"
                />
              );
            })}

            {/* Axis lines */}
            {skills.map((_, i) => {
              const pos = getPosition(i, maxRadius);
              return (
                <line
                  x1={centerX}
                  y1={centerY}
                  x2={pos.x}
                  y2={pos.y}
                  stroke="currentColor"
                  stroke-width="1"
                  class="text-gray-200 dark:text-gray-700"
                />
              );
            })}

            {/* Filled area */}
            <polygon
              points={getPolygonPoints(skills)}
              fill="url(#radarGradient)"
              stroke="#8B5CF6"
              stroke-width="2"
              class="radar-area"
            />

            {/* Gradient definition */}
            <defs>
              <linearGradient id="radarGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" style="stop-color:#8B5CF6;stop-opacity:0.3" />
                <stop offset="100%" style="stop-color:#22c55e;stop-opacity:0.3" />
              </linearGradient>
            </defs>

            {/* Skill points (clickable) */}
            {skills.map((skill, i) => {
              const radius = (skill.level / 100) * maxRadius;
              const pos = getPosition(i, radius);
              const labelPos = getPosition(i, maxRadius + 25);
              return (
                <>
                  {/* Clickable point */}
                  <circle
                    cx={pos.x}
                    cy={pos.y}
                    r="8"
                    fill="#8B5CF6"
                    stroke="white"
                    stroke-width="2"
                    class="skill-point cursor-pointer hover:r-10 transition-all"
                    data-skill-id={skill.id}
                  />
                  {/* Label */}
                  <text
                    x={labelPos.x}
                    y={labelPos.y}
                    text-anchor="middle"
                    dominant-baseline="middle"
                    class="text-xs font-medium fill-gray-700 dark:fill-gray-300 cursor-pointer skill-label"
                    data-skill-id={skill.id}
                  >
                    {skill.shortName}
                  </text>
                </>
              );
            })}
          </svg>
        </div>

        {/* Skills List */}
        <div class="flex-1 w-full">
          <div class="space-y-3">
            {skills.map((skill) => (
              <button
                class="skill-button w-full text-left p-4 rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-umai-gray-800 hover:border-umai-accent hover:shadow-md transition-all"
                data-skill-id={skill.id}
              >
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-lg bg-umai-accent/20 flex items-center justify-center">
                      <svg class="w-4 h-4 text-umai-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <Fragment set:html={skill.icon} />
                      </svg>
                    </div>
                    <span class="font-medium text-gray-900 dark:text-gray-100">{skill.name}</span>
                  </div>
                  <div class="flex items-center gap-2">
                    <div class="w-24 h-2 bg-gray-200 dark:bg-gray-700 rounded-full overflow-hidden">
                      <div
                        class="h-full bg-gradient-to-r from-umai-accent to-green-500 rounded-full"
                        style={`width: ${skill.level}%`}
                      />
                    </div>
                    <span class="text-xs text-gray-500 dark:text-gray-400 w-8">{skill.level}%</span>
                  </div>
                </div>
              </button>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>

  {/* Modal for skill details */}
  <div id="skill-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-black/50 backdrop-blur-sm">
    <div class="bg-white dark:bg-umai-gray-800 rounded-xl shadow-2xl max-w-lg w-full max-h-[80vh] overflow-hidden">
      {/* Modal Header */}
      <div class="p-6 border-b border-gray-200 dark:border-gray-700 bg-gradient-to-r from-umai-accent/10 to-green-500/10">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-3">
            <div id="modal-icon" class="w-10 h-10 rounded-xl bg-umai-accent flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
            </div>
            <div>
              <h3 id="modal-title" class="text-lg font-bold text-gray-900 dark:text-white">Skill Name</h3>
              <div class="flex items-center gap-2 mt-1">
                <div class="w-20 h-1.5 bg-gray-200 dark:bg-gray-700 rounded-full overflow-hidden">
                  <div id="modal-level-bar" class="h-full bg-umai-accent rounded-full" style="width: 80%"></div>
                </div>
                <span id="modal-level" class="text-xs text-gray-500 dark:text-gray-400">80%</span>
              </div>
            </div>
          </div>
          <button id="modal-close" class="p-2 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition-colors">
            <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
      </div>

      {/* Modal Body */}
      <div class="p-6 space-y-4 overflow-y-auto max-h-[50vh]">
        <div>
          <h4 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-2">What It Is</h4>
          <p id="modal-description" class="text-gray-700 dark:text-gray-300 leading-relaxed">
            Description goes here...
          </p>
        </div>

        <div class="bg-green-50 dark:bg-green-950/30 rounded-lg p-4 border border-green-200 dark:border-green-800/40">
          <h4 class="text-sm font-semibold text-green-700 dark:text-green-400 mb-2 flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
            </svg>
            How to Develop It
          </h4>
          <p id="modal-develop" class="text-green-800 dark:text-green-300 text-sm leading-relaxed">
            Development tips go here...
          </p>
        </div>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ skills }}>
  function initSkillsRadar() {
    const modal = document.getElementById('skill-modal');
    const modalTitle = document.getElementById('modal-title');
    const modalDescription = document.getElementById('modal-description');
    const modalDevelop = document.getElementById('modal-develop');
    const modalLevel = document.getElementById('modal-level');
    const modalLevelBar = document.getElementById('modal-level-bar');
    const modalClose = document.getElementById('modal-close');
    const modalIcon = document.getElementById('modal-icon');

    if (!modal || !modalTitle || !modalDescription || !modalDevelop || !modalClose) return;

    // Skill data map
    const skillMap = new Map();
    skills.forEach(skill => skillMap.set(skill.id, skill));

    function openModal(skillId) {
      const skill = skillMap.get(skillId);
      if (!skill) return;

      modalTitle.textContent = skill.name;
      modalDescription.textContent = skill.description;
      modalDevelop.textContent = skill.developBy;
      if (modalLevel) modalLevel.textContent = skill.level + '%';
      if (modalLevelBar) modalLevelBar.style.width = skill.level + '%';
      if (modalIcon) {
        modalIcon.innerHTML = `<svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">${skill.icon}</svg>`;
      }

      modal.classList.remove('hidden');
      modal.classList.add('flex');
    }

    function closeModal() {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
    }

    // Click handlers for skill points and labels
    document.querySelectorAll('[data-skill-id]').forEach(el => {
      el.addEventListener('click', (e) => {
        const target = e.currentTarget;
        const skillId = target ? target.dataset.skillId : null;
        if (skillId) openModal(skillId);
      });
    });

    // Close modal
    modalClose.addEventListener('click', closeModal);
    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });

    // ESC key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeModal();
    });
  }

  // Initialize
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSkillsRadar);
  } else {
    initSkillsRadar();
  }
</script>

<style>
  .skill-point {
    transition: all 0.2s ease;
  }

  .skill-point:hover {
    r: 10;
    filter: drop-shadow(0 0 8px rgba(139, 92, 246, 0.5));
  }

  .skill-label {
    transition: all 0.2s ease;
  }

  .skill-label:hover {
    fill: #8B5CF6;
  }

  .radar-area {
    transition: all 0.3s ease;
  }

  .skills-radar:hover .radar-area {
    filter: drop-shadow(0 0 12px rgba(139, 92, 246, 0.3));
  }

  .skill-button:hover {
    transform: translateX(4px);
  }

  #skill-modal {
    animation: fadeIn 0.2s ease;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  #skill-modal > div {
    animation: slideUp 0.2s ease;
  }

  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

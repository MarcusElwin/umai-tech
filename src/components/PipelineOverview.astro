---
/**
 * PipelineOverview - High-level visualization of a recommendation pipeline
 *
 * Displays a horizontal flow diagram showing the stages of processing
 * from input to output. Follows Umai design system:
 * - Primary color: Umai Purple (#8B5CF6)
 * - Consistent SVG icons
 * - Responsive with mobile stacking
 * - Dark mode support
 */

export interface PipelineStep {
  label: string;
  sublabel?: string;
  iconType: 'input' | 'generate' | 'rank' | 'filter' | 'output';
  color: string;
}

export interface Props {
  title?: string;
  subtitle?: string;
  steps: PipelineStep[];
}

const { title, subtitle, steps } = Astro.props;

const stepIcons = {
  input: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  generate: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>`,
  rank: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>`,
  filter: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/></svg>`,
  output: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>`
};
---

<div class="pipeline-overview my-10">
  {(title || subtitle) && (
    <div class="text-center mb-8">
      {title && <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">{title}</h3>}
      {subtitle && <p class="text-gray-600 dark:text-gray-400 text-sm">{subtitle}</p>}
    </div>
  )}

  <!-- Desktop View: Horizontal Flow -->
  <div class="hidden md:block">
    <div class="pipeline-desktop-container relative bg-gradient-to-r from-gray-50 via-white to-gray-50 dark:from-gray-900 dark:via-gray-800 dark:to-gray-900 rounded-2xl border border-gray-200 dark:border-gray-700 p-8 overflow-hidden">
      <div class="relative flex items-center justify-between gap-2">
        {steps.map((step, index) => (
          <div class="flex items-center flex-1">
            <!-- Step Card -->
            <div class="pipeline-step flex-1 group">
              <div
                class="relative p-5 rounded-xl border-2 transition-all duration-300 hover:shadow-lg hover:-translate-y-1"
                style={`border-color: ${step.color}30; background: linear-gradient(135deg, ${step.color}08 0%, ${step.color}15 100%);`}
              >
                <!-- Icon -->
                <div
                  class="w-12 h-12 rounded-xl flex items-center justify-center mb-3 mx-auto shadow-lg transition-transform duration-300 group-hover:scale-110"
                  style={`background: linear-gradient(135deg, ${step.color} 0%, ${step.color}cc 100%);`}
                >
                  <span class="text-white">
                    <Fragment set:html={stepIcons[step.iconType]} />
                  </span>
                </div>

                <!-- Label -->
                <div class="text-center">
                  <h4 class="font-bold text-gray-900 dark:text-white text-sm mb-1">
                    {step.label}
                  </h4>
                  {step.sublabel && (
                    <p class="text-xs text-gray-500 dark:text-gray-400">
                      {step.sublabel}
                    </p>
                  )}
                </div>

                <!-- Step Number -->
                <div
                  class="absolute -top-2 -right-2 w-6 h-6 rounded-full text-white text-xs font-bold flex items-center justify-center shadow-md"
                  style={`background-color: ${step.color};`}
                >
                  {index + 1}
                </div>
              </div>
            </div>

            <!-- Arrow Connector -->
            {index < steps.length - 1 && (
              <div class="flex-shrink-0 px-2">
                <div class="flex items-center">
                  <div class="w-8 h-0.5 bg-gradient-to-r from-gray-300 to-gray-400 dark:from-gray-600 dark:to-gray-500"></div>
                  <svg class="w-4 h-4 text-gray-400 dark:text-gray-500 -ml-1" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"/>
                  </svg>
                </div>
              </div>
            )}
          </div>
        ))}
      </div>

      <!-- Flow Label -->
      <div class="mt-6 flex justify-center">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-purple-100 dark:bg-purple-900/30 border border-purple-200 dark:border-purple-800">
          <svg class="w-4 h-4 text-purple-600 dark:text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
          <span class="text-xs font-medium text-purple-700 dark:text-purple-300">
            Data flows left to right through each processing stage
          </span>
        </div>
      </div>
    </div>
  </div>

  <!-- Mobile View: Vertical Flow -->
  <div class="md:hidden">
    <div class="relative bg-gradient-to-b from-gray-50 via-white to-gray-50 dark:from-gray-900 dark:via-gray-800 dark:to-gray-900 rounded-2xl border border-gray-200 dark:border-gray-700 p-6">
      <div class="space-y-4">
        {steps.map((step, index) => (
          <div class="flex flex-col items-center">
            <!-- Step Card -->
            <div
              class="w-full p-4 rounded-xl border-2 transition-all duration-300"
              style={`border-color: ${step.color}30; background: linear-gradient(135deg, ${step.color}08 0%, ${step.color}15 100%);`}
            >
              <div class="flex items-center gap-4">
                <!-- Icon -->
                <div
                  class="w-12 h-12 rounded-xl flex items-center justify-center shadow-lg flex-shrink-0"
                  style={`background: linear-gradient(135deg, ${step.color} 0%, ${step.color}cc 100%);`}
                >
                  <span class="text-white">
                    <Fragment set:html={stepIcons[step.iconType]} />
                  </span>
                </div>

                <!-- Content -->
                <div class="flex-1">
                  <div class="flex items-center gap-2">
                    <span
                      class="w-5 h-5 rounded-full text-white text-xs font-bold flex items-center justify-center"
                      style={`background-color: ${step.color};`}
                    >
                      {index + 1}
                    </span>
                    <h4 class="font-bold text-gray-900 dark:text-white text-sm">
                      {step.label}
                    </h4>
                  </div>
                  {step.sublabel && (
                    <p class="text-xs text-gray-500 dark:text-gray-400 mt-1 ml-7">
                      {step.sublabel}
                    </p>
                  )}
                </div>
              </div>
            </div>

            <!-- Arrow Down -->
            {index < steps.length - 1 && (
              <div class="py-2">
                <svg class="w-5 h-5 text-gray-400 dark:text-gray-500" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z"/>
                </svg>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>
</div>

<style>
  .pipeline-step {
    min-width: 140px;
  }

  @media (min-width: 768px) {
    .pipeline-step:hover + div + .pipeline-step .relative {
      border-color: rgba(139, 92, 246, 0.3);
    }
  }
</style>

---
export interface Stage {
  name: string;
  iconType: 'source' | 'hydrator' | 'filter' | 'scorer' | 'selector' | 'sideeffect';
  execution: 'parallel' | 'sequential' | 'async';
  description: string;
  details: string[];
  color: string;
}

export interface Props {
  title: string;
  subtitle?: string;
  stages: Stage[];
  domain?: 'twitter' | 'ecommerce';
}

const { title, subtitle, stages, domain = 'twitter' } = Astro.props;

const executionStyles = {
  parallel: {
    bg: 'bg-emerald-100 dark:bg-emerald-900/40',
    border: 'border-emerald-300 dark:border-emerald-700',
    text: 'text-emerald-700 dark:text-emerald-300',
    label: 'Parallel'
  },
  sequential: {
    bg: 'bg-amber-100 dark:bg-amber-900/40',
    border: 'border-amber-300 dark:border-amber-700',
    text: 'text-amber-700 dark:text-amber-300',
    label: 'Sequential'
  },
  async: {
    bg: 'bg-blue-100 dark:bg-blue-900/40',
    border: 'border-blue-300 dark:border-blue-700',
    text: 'text-blue-700 dark:text-blue-300',
    label: 'Async'
  }
};

const executionIcons = {
  parallel: `<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`,
  sequential: `<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>`,
  async: `<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`
};

const stageIcons = {
  source: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.141 0M1.394 9.393c5.857-5.857 15.355-5.857 21.213 0"/></svg>`,
  hydrator: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>`,
  filter: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/></svg>`,
  scorer: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>`,
  selector: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>`,
  sideeffect: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>`
};

const domainColors = {
  twitter: 'from-sky-500 to-blue-600',
  ecommerce: 'from-purple-500 to-pink-600'
};

const componentId = `pipeline-${Math.random().toString(36).slice(2, 11)}`;
---

<div class="pipeline-stage-container my-12">
  <!-- Header -->
  <div class={`bg-gradient-to-r ${domainColors[domain]} rounded-t-2xl p-6 text-white`}>
    <h3 class="text-xl font-bold mb-1">{title}</h3>
    {subtitle && <p class="text-white/80 text-sm">{subtitle}</p>}
  </div>

  <!-- Legend -->
  <div class="bg-gray-50 dark:bg-gray-800/50 border-x border-gray-200 dark:border-gray-700 px-6 py-3 flex flex-wrap gap-4 text-sm">
    {Object.entries(executionStyles).map(([key, style]) => (
      <div class="flex items-center gap-2">
        <span class={`inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium ${style.bg} ${style.text} ${style.border} border`}>
          <Fragment set:html={executionIcons[key as keyof typeof executionIcons]} />
          {style.label}
        </span>
        <span class="text-gray-500 dark:text-gray-400 text-xs">
          {key === 'parallel' && 'Independent operations'}
          {key === 'sequential' && 'Depends on previous'}
          {key === 'async' && 'Background tasks'}
        </span>
      </div>
    ))}
  </div>

  <!-- Pipeline Flow -->
  <div class="bg-white dark:bg-gray-900 border border-t-0 border-gray-200 dark:border-gray-700 rounded-b-2xl p-6 overflow-x-auto">
    <div class="flex items-stretch gap-2 min-w-max">
      {stages.map((stage, index) => {
        const execStyle = executionStyles[stage.execution];
        return (
          <div class="flex items-center">
            <!-- Stage Card -->
            <div
              class={`stage-card relative flex flex-col w-48 rounded-xl border-2 ${execStyle.border} overflow-hidden transition-all duration-300 hover:shadow-lg cursor-pointer group`}
              data-stage-id={`${componentId}-${index}`}
            >
              <!-- Stage Header -->
              <div class={`${execStyle.bg} px-4 py-3 border-b ${execStyle.border}`}>
                <div class="flex items-center justify-between">
                  <div class="text-gray-700 dark:text-gray-200">
                    <Fragment set:html={stageIcons[stage.iconType]} />
                  </div>
                  <span class={`text-xs font-medium ${execStyle.text} px-2 py-0.5 rounded-full bg-white/50 dark:bg-black/20 flex items-center gap-1`}>
                    <Fragment set:html={executionIcons[stage.execution]} />
                    {execStyle.label}
                  </span>
                </div>
                <h4 class="font-bold text-gray-900 dark:text-white mt-2 text-sm uppercase tracking-wide">
                  {stage.name}
                </h4>
              </div>

              <!-- Stage Description -->
              <div class="px-4 py-3 bg-white dark:bg-gray-800 flex-1">
                <p class="text-xs text-gray-600 dark:text-gray-300 leading-relaxed">
                  {stage.description}
                </p>
              </div>

              <!-- Expand Indicator -->
              <div class="px-4 py-2 bg-gray-50 dark:bg-gray-800/50 border-t border-gray-100 dark:border-gray-700">
                <span class="text-xs text-gray-400 dark:text-gray-500 flex items-center gap-1 group-hover:text-purple-500 transition-colors">
                  <svg class="w-3 h-3 transition-transform group-hover:translate-y-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                  Click for details
                </span>
              </div>

              <!-- Expanded Details (Hidden by default) -->
              <div
                class="stage-details hidden absolute top-full left-0 right-0 mt-2 z-20 bg-white dark:bg-gray-800 rounded-xl shadow-xl border border-gray-200 dark:border-gray-700 p-4"
                id={`${componentId}-${index}-details`}
              >
                <h5 class="font-semibold text-gray-900 dark:text-white text-sm mb-2">
                  {stage.name} Details:
                </h5>
                <ul class="space-y-1.5">
                  {stage.details.map((detail) => (
                    <li class="text-xs text-gray-600 dark:text-gray-300 flex items-start gap-2">
                      <span class={`w-1.5 h-1.5 rounded-full mt-1.5 flex-shrink-0`} style={`background-color: ${stage.color}`}></span>
                      {detail}
                    </li>
                  ))}
                </ul>
              </div>
            </div>

            <!-- Arrow Connector -->
            {index < stages.length - 1 && (
              <div class="flex items-center px-1">
                <svg class="w-6 h-6 text-gray-300 dark:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </div>
            )}
          </div>
        );
      })}
    </div>
  </div>
</div>

<script is:inline define:vars={{ componentId }}>
  (function() {
    function initPipeline() {
      const cards = document.querySelectorAll(`[data-stage-id^="${componentId}"]`);

      cards.forEach(card => {
        const stageId = card.getAttribute('data-stage-id');
        const details = document.getElementById(`${stageId}-details`);

        if (!details) return;

        card.addEventListener('click', (e) => {
          e.stopPropagation();

          // Close all other details
          document.querySelectorAll(`[id^="${componentId}"][id$="-details"]`).forEach(d => {
            if (d !== details) d.classList.add('hidden');
          });

          // Toggle current details
          details.classList.toggle('hidden');
        });
      });

      // Close details when clicking outside
      document.addEventListener('click', () => {
        document.querySelectorAll(`[id^="${componentId}"][id$="-details"]`).forEach(d => {
          d.classList.add('hidden');
        });
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initPipeline);
    } else {
      initPipeline();
    }
  })();
</script>

<style>
  .stage-card {
    min-height: 180px;
  }

  .stage-details {
    animation: slideDown 0.2s ease-out;
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Scrollbar styling for overflow */
  .pipeline-stage-container .overflow-x-auto::-webkit-scrollbar {
    height: 6px;
  }

  .pipeline-stage-container .overflow-x-auto::-webkit-scrollbar-track {
    background: #f1f1f1;
    border-radius: 3px;
  }

  .pipeline-stage-container .overflow-x-auto::-webkit-scrollbar-thumb {
    background: #c1c1c1;
    border-radius: 3px;
  }

  .dark .pipeline-stage-container .overflow-x-auto::-webkit-scrollbar-track {
    background: #374151;
  }

  .dark .pipeline-stage-container .overflow-x-auto::-webkit-scrollbar-thumb {
    background: #6b7280;
  }
</style>

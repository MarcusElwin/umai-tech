---
export interface Props {
  title: string;
  description: string;
  filterQuestion: string;
  passingTraits: Array<{
    trait: string;
    description: string;
  }>;
  failingTraits: Array<{
    trait: string;
    description: string;
  }>;
}

const { title, description, filterQuestion, passingTraits, failingTraits } = Astro.props;
---

<div class="career-filter my-10">
  <div class="bg-gradient-to-r from-umai-gray-50 to-white dark:from-umai-gray-800 dark:to-umai-gray-700 rounded-xl border border-umai-gray-200 dark:border-umai-gray-600 overflow-hidden">
    {/* Header */}
    <div class="p-6 border-b border-umai-gray-200 dark:border-umai-gray-600">
      <h4 class="text-xl font-bold text-gray-900 dark:text-white mb-2">{title}</h4>
      <p class="text-gray-600 dark:text-gray-400 text-sm">{description}</p>
    </div>

    {/* Filter Question */}
    <div class="bg-umai-accent/10 dark:bg-umai-accent/20 px-6 py-4 border-b border-umai-gray-200 dark:border-umai-gray-600">
      <div class="flex items-center gap-3">
        <svg class="w-6 h-6 text-umai-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <p class="text-umai-accent dark:text-umai-accent font-semibold text-lg italic">
          "{filterQuestion}"
        </p>
      </div>
    </div>

    {/* Two Columns */}
    <div class="grid md:grid-cols-2">
      {/* Passing Side */}
      <div class="p-6 bg-green-50/50 dark:bg-green-950/20 border-r border-umai-gray-200 dark:border-umai-gray-600">
        <div class="flex items-center gap-2 mb-4">
          <div class="w-8 h-8 rounded-full bg-green-500 flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
          </div>
          <h5 class="font-bold text-green-700 dark:text-green-400">Thriving</h5>
        </div>
        <div class="space-y-3">
          {passingTraits.map((item) => (
            <div class="bg-white dark:bg-umai-gray-800 rounded-lg p-3 border border-green-200 dark:border-green-800/40">
              <div class="font-medium text-gray-900 dark:text-gray-100 text-sm mb-1">{item.trait}</div>
              <div class="text-xs text-gray-600 dark:text-gray-400">{item.description}</div>
            </div>
          ))}
        </div>
      </div>

      {/* Failing Side */}
      <div class="p-6 bg-red-50/50 dark:bg-red-950/20">
        <div class="flex items-center gap-2 mb-4">
          <div class="w-8 h-8 rounded-full bg-red-500 flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </div>
          <h5 class="font-bold text-red-700 dark:text-red-400">At Risk</h5>
        </div>
        <div class="space-y-3">
          {failingTraits.map((item) => (
            <div class="bg-white dark:bg-umai-gray-800 rounded-lg p-3 border border-red-200 dark:border-red-800/40">
              <div class="font-medium text-gray-900 dark:text-gray-100 text-sm mb-1">{item.trait}</div>
              <div class="text-xs text-gray-600 dark:text-gray-400">{item.description}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .career-filter {
    transition: all 0.3s ease;
  }

  .career-filter:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1);
  }
</style>

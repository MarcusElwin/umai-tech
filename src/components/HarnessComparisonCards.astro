---
const rows = [
  {
    dimension: 'Best use case',
    inApp: 'Learning, demos, local dev, fast iteration.',
    iii: 'Production-ish runs that need durable state, policy, budgets, and traces.',
  },
  {
    dimension: 'Mental model',
    inApp: 'One app owns the route, loop, tools, events, and UI.',
    iii: 'Engine plus workers; each harness concern can be a worker.',
  },
  {
    dimension: 'Streaming',
    inApp: 'Simple SSE from the Next.js route.',
    iii: 'Worker emits events through engine/channel/stream paths; app forwards them.',
  },
  {
    dimension: 'Tool policy',
    inApp: 'Whatever I code inline. Initially: nothing.',
    iii: 'A policy function can gate calls and fail closed.',
  },
  {
    dimension: 'Budget control',
    inApp: 'Estimate and display cost.',
    iii: 'Budget can become a runtime enforcement concern.',
  },
  {
    dimension: 'Sessions',
    inApp: 'Browser-local history.',
    iii: 'Server-side state keyed by conversation/session.',
  },
  {
    dimension: 'Human approval',
    inApp: 'Easy to prototype, fragile in one process.',
    iii: 'Can be backed by durable state/queue mechanics.',
  },
  {
    dimension: 'Observability',
    inApp: 'UI timeline plus logs.',
    iii: 'Cross-worker traces are part of the substrate.',
  },
  {
    dimension: 'Provider support',
    inApp: 'Great through the AI SDK, request-scoped in my app.',
    iii: 'Provider workers make model access another replaceable layer.',
  },
  {
    dimension: 'Deployment',
    inApp: 'One Next.js app.',
    iii: 'Next.js app plus engine/workers. More power, more ops.',
  },
];
---

<section class="not-prose my-8 rounded-3xl border border-umai-gray-200 bg-white p-5 shadow-2xl shadow-umai-gray-900/10 dark:border-umai-gray-700 dark:bg-umai-gray-900/80 sm:p-6" aria-labelledby="harness-compare-title">
  <div class="mb-6 border-b border-umai-gray-200 pb-5 dark:border-umai-gray-700">
    <div class="mb-2 text-xs font-bold uppercase tracking-[0.18em] text-umai-accent">migration ledger</div>
    <h3 id="harness-compare-title" class="text-2xl font-bold tracking-tight text-umai-primary dark:text-umai-secondary sm:text-3xl">
      Thin app harness vs worker substrate
    </h3>
    <div class="mt-3 text-sm leading-7 text-umai-gray-600 dark:text-umai-gray-300">
      Same product surface, different runtime responsibilities. The useful comparison isn&rsquo;t who&rsquo;s
      &ldquo;better&rdquo; &mdash; it&rsquo;s where each harness shape puts the work.
    </div>
  </div>

  <div class="mb-4 hidden gap-4 sm:grid sm:grid-cols-2">
    <div class="flex items-center justify-between gap-3 rounded-2xl border border-umai-gray-200 bg-umai-gray-50 p-4 dark:border-umai-gray-700 dark:bg-umai-gray-800/70">
      <div>
        <div class="text-lg font-bold tracking-tight text-umai-gray-900 dark:text-white">AI SDK harness</div>
        <div class="mt-1 text-xs font-semibold uppercase tracking-[0.14em] text-umai-gray-400">thin app runtime</div>
      </div>
      <span class="rounded-full bg-umai-primary px-3 py-1 text-[0.68rem] font-bold uppercase tracking-[0.14em] text-white dark:bg-umai-secondary dark:text-umai-primary">
        current
      </span>
    </div>
    <div class="flex items-center justify-between gap-3 rounded-2xl bg-gradient-to-r from-umai-accent to-umai-accent-dark p-4">
      <div>
        <div class="text-lg font-bold tracking-tight text-white">iii substrate</div>
        <div class="mt-1 text-xs font-semibold uppercase tracking-[0.14em] text-white/75">engine + composable workers</div>
      </div>
      <a
        href="https://iii.dev"
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-full bg-white px-3 py-1 text-[0.68rem] font-bold uppercase tracking-[0.14em] text-umai-accent transition-colors hover:bg-umai-secondary"
      >
        iii.dev ↗
      </a>
    </div>
  </div>

  <div class="space-y-3">
    {rows.map((row) => (
      <article class="rounded-2xl border border-umai-gray-200 bg-umai-gray-50 p-4 dark:border-umai-gray-700 dark:bg-umai-gray-800/70">
        <div class="text-[0.68rem] font-bold uppercase tracking-[0.16em] text-umai-gray-400">{row.dimension}</div>
        <div class="mt-3 grid gap-3 sm:grid-cols-2">
          <div class="rounded-xl border border-umai-gray-200 bg-white p-3 dark:border-umai-gray-700 dark:bg-umai-gray-900">
            <div class="mb-1 text-[0.62rem] font-bold uppercase tracking-[0.14em] text-umai-gray-400 sm:hidden">AI SDK harness</div>
            <div class="text-sm leading-6 text-umai-gray-700 dark:text-umai-gray-300">{row.inApp}</div>
          </div>
          <div class="rounded-xl border border-umai-accent/25 bg-umai-accent/10 p-3 dark:border-umai-accent/30 dark:bg-umai-accent/15">
            <div class="mb-1 text-[0.62rem] font-bold uppercase tracking-[0.14em] text-umai-accent sm:hidden">iii substrate</div>
            <div class="text-sm leading-6 text-umai-gray-700 dark:text-umai-gray-200">{row.iii}</div>
          </div>
        </div>
      </article>
    ))}
  </div>
</section>

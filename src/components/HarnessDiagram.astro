---
export interface Props {
  title?: string;
  subtitle?: string;
}

const { title = 'The Agentic Harness', subtitle } = Astro.props;
const componentId = `harness-${Math.random().toString(36).slice(2, 11)}`;

const mainFlow = [
  { id: 'ic', label: 'Intent Capture', icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>` },
  { id: 'td', label: 'Task Decomposition', icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>` },
  { id: 'ce', label: 'Cognitive Engine', sublabel: '(LLM)', icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>`, primary: true },
  { id: 'ro', label: 'Reasoning Orchestrator', sublabel: '(Deterministic Validation)', icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`, accent: true },
  { id: 'te', label: 'Tool Execution', icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>` },
  { id: 'vl', label: 'Verification Loop', icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>` },
];

const sideModules = [
  { id: 'mem', label: 'Memory & Context', target: 'ce', icon: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"/></svg>` },
  { id: 'gr', label: 'Guardrails & Compliance', target: 'ro', icon: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>` },
  { id: 'obs', label: 'Observability & Monitoring', target: 'te', icon: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>` },
];

const descriptions: Record<string, string> = {
  ic: 'Captures user intent and translates it into a structured request the system can act on.',
  td: 'Breaks complex requests into discrete, executable sub-tasks with clear dependencies.',
  ce: 'The LLM core — drafts probabilistic plans and generates reasoning. Swappable across providers.',
  ro: 'Validates LLM output against business rules, access controls, and compliance requirements before execution.',
  te: 'Dispatches validated actions to external tools — APIs, browsers, terminals, file systems.',
  vl: 'Checks execution results against expected outcomes. Routes back to the Cognitive Engine on failure, or emits output on success.',
  mem: 'Manages session state, episodic memory, and working context. Feeds relevant history into the Cognitive Engine.',
  gr: 'Enforces deterministic safety rules on probabilistic outputs — the boundary between "what the LLM wants" and "what\'s allowed."',
  obs: 'Monitors for hallucination, drift, latency, and failure patterns across the execution pipeline.',
};
---

<div class="harness-wrapper my-10" id={componentId}>
  {/* Header */}
  <div class="text-center mb-8">
    <h4 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">{title}</h4>
    {subtitle && <p class="text-sm text-gray-500 dark:text-gray-400 max-w-xl mx-auto">{subtitle}</p>}
  </div>

  {/* Diagram Container */}
  <div class="rounded-xl border border-purple-200/40 dark:border-purple-800/30 bg-gradient-to-b from-gray-50/80 to-white dark:from-gray-900/60 dark:to-gray-900/40 p-6 md:p-8 backdrop-blur-sm">
    <div class="flex flex-col md:flex-row gap-6">
      {/* Main Flow Column */}
      <div class="flex-1">
        <div class="space-y-0">
          {mainFlow.map((node, i) => (
            <div>
              <button
                class={`harness-node w-full text-left rounded-lg border px-4 py-3 flex items-center gap-3 transition-all duration-200 cursor-pointer group
                  ${node.primary
                    ? 'border-purple-300/60 dark:border-purple-600/40 bg-gradient-to-r from-purple-50 to-purple-100/50 dark:from-purple-900/30 dark:to-purple-800/20 hover:shadow-md hover:shadow-purple-500/10'
                    : node.accent
                      ? 'border-violet-300/60 dark:border-violet-600/40 bg-gradient-to-r from-violet-50 to-violet-100/50 dark:from-violet-900/30 dark:to-violet-800/20 hover:shadow-md hover:shadow-violet-500/10'
                      : 'border-gray-200/60 dark:border-gray-700/40 bg-white/80 dark:bg-gray-800/40 hover:shadow-md hover:border-purple-300/40 dark:hover:border-purple-600/30'
                  }`}
                data-harness-btn={componentId}
                data-node={node.id}
                aria-label={node.label}
              >
                <div class={`flex-shrink-0 w-9 h-9 rounded-lg flex items-center justify-center transition-colors
                  ${node.primary
                    ? 'bg-purple-500 text-white shadow-sm shadow-purple-500/30'
                    : node.accent
                      ? 'bg-violet-500 text-white shadow-sm shadow-violet-500/30'
                      : 'bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 group-hover:bg-purple-100 dark:group-hover:bg-purple-900/30 group-hover:text-purple-600 dark:group-hover:text-purple-400'
                  }`}>
                  <Fragment set:html={node.icon} />
                </div>
                <div class="flex-1 min-w-0">
                  <span class={`text-sm font-medium block ${node.primary || node.accent ? 'text-gray-900 dark:text-white' : 'text-gray-700 dark:text-gray-200'}`}>{node.label}</span>
                  {node.sublabel && <span class="text-xs text-gray-500 dark:text-gray-400">{node.sublabel}</span>}
                </div>
                <svg class="w-4 h-4 text-gray-400 dark:text-gray-500 flex-shrink-0 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </button>

              {/* Arrow between nodes */}
              {i < mainFlow.length - 1 && (
                <div class="flex items-center justify-center h-6">
                  <div class="flex flex-col items-center">
                    <div class="w-px h-3 bg-purple-300/50 dark:bg-purple-600/30"></div>
                    <svg class="w-3 h-3 text-purple-400/60 dark:text-purple-500/40" fill="currentColor" viewBox="0 0 12 12">
                      <path d="M6 9L1 4h10L6 9z"/>
                    </svg>
                  </div>
                </div>
              )}

              {/* Iteration arrow after Verification Loop */}
              {node.id === 'vl' && (
                <div class="flex items-center gap-2 mt-2 ml-4">
                  <div class="flex items-center gap-1 text-xs text-purple-500/70 dark:text-purple-400/50">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                    </svg>
                    <span class="italic">Iterates back to Cognitive Engine on failure</span>
                  </div>
                </div>
              )}
            </div>
          ))}

          {/* Output */}
          <div class="flex items-center justify-center h-6">
            <div class="flex flex-col items-center">
              <div class="w-px h-3 bg-emerald-300/50 dark:bg-emerald-600/30"></div>
              <svg class="w-3 h-3 text-emerald-400/60 dark:text-emerald-500/40" fill="currentColor" viewBox="0 0 12 12">
                <path d="M6 9L1 4h10L6 9z"/>
              </svg>
            </div>
          </div>
          <div class="w-full rounded-lg border border-emerald-300/60 dark:border-emerald-700/40 bg-emerald-50/50 dark:bg-emerald-900/20 px-4 py-3 flex items-center gap-3">
            <div class="flex-shrink-0 w-9 h-9 rounded-lg bg-emerald-500 text-white flex items-center justify-center shadow-sm shadow-emerald-500/30">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <span class="text-sm font-medium text-emerald-700 dark:text-emerald-300">Output</span>
          </div>
        </div>
      </div>

      {/* Side Modules Column */}
      <div class="md:w-52 flex md:flex-col gap-3 md:justify-center">
        <div class="text-xs font-medium text-gray-400 dark:text-gray-500 uppercase tracking-wider mb-1 hidden md:block text-center">Supporting Layers</div>
        {sideModules.map((mod) => (
          <button
            class="harness-side-node flex-1 md:flex-none rounded-lg border border-dashed border-purple-200/50 dark:border-purple-700/30 bg-purple-50/30 dark:bg-purple-900/10 px-3 py-2.5 flex items-center gap-2 transition-all duration-200 cursor-pointer hover:border-purple-300/60 dark:hover:border-purple-600/40 hover:bg-purple-50/60 dark:hover:bg-purple-900/20 group"
            data-harness-btn={componentId}
            data-node={mod.id}
            aria-label={mod.label}
          >
            <div class="flex-shrink-0 w-7 h-7 rounded-md bg-purple-100/80 dark:bg-purple-800/30 text-purple-500 dark:text-purple-400 flex items-center justify-center group-hover:bg-purple-200/80 dark:group-hover:bg-purple-700/30 transition-colors">
              <Fragment set:html={mod.icon} />
            </div>
            <span class="text-xs font-medium text-gray-600 dark:text-gray-400 leading-tight">{mod.label}</span>
          </button>
        ))}
        <div class="hidden md:flex items-center gap-1 text-xs text-gray-400 dark:text-gray-500 justify-center mt-1">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18"/>
          </svg>
          <span class="italic">feeds into main flow</span>
        </div>
      </div>
    </div>
  </div>

  {/* Description Panel */}
  <div class="mt-4 min-h-[60px]" id={`${componentId}-desc`}>
    <div class="rounded-lg border border-gray-200/60 dark:border-gray-700/40 bg-white/80 dark:bg-gray-800/40 p-4 text-center transition-all duration-300">
      <p class="text-sm text-gray-500 dark:text-gray-400 italic">Click any component to see what it does</p>
    </div>
  </div>
</div>

<script define:vars={{ componentId, descriptions }} is:inline>
  function initHarness() {
    const wrapper = document.getElementById(componentId);
    if (!wrapper) { setTimeout(initHarness, 100); return; }

    const descPanel = document.getElementById(componentId + '-desc');
    const buttons = wrapper.querySelectorAll('[data-harness-btn="' + componentId + '"]');

    buttons.forEach(function(btn) {
      btn.addEventListener('click', function() {
        var nodeId = this.getAttribute('data-node');
        var desc = descriptions[nodeId] || '';
        var label = this.querySelector('span').textContent;

        // Reset all highlights
        buttons.forEach(function(b) {
          b.classList.remove('ring-2', 'ring-purple-400/50', 'dark:ring-purple-500/40', 'shadow-md');
        });

        // Highlight active
        this.classList.add('ring-2', 'ring-purple-400/50', 'dark:ring-purple-500/40', 'shadow-md');

        // Update description
        if (descPanel) {
          descPanel.innerHTML =
            '<div class="rounded-lg border border-purple-200/60 dark:border-purple-700/40 bg-purple-50/50 dark:bg-purple-900/20 p-4 transition-all duration-300">' +
              '<p class="font-semibold text-gray-900 dark:text-gray-100 text-sm mb-1">' + label + '</p>' +
              '<p class="text-sm text-gray-600 dark:text-gray-300">' + desc + '</p>' +
            '</div>';
        }
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHarness);
  } else {
    initHarness();
  }
</script>

<style>
  .harness-node, .harness-side-node {
    animation: harnessFadeIn 0.4s ease-out both;
  }

  .harness-node:nth-child(1) { animation-delay: 0.05s; }
  .harness-node:nth-child(3) { animation-delay: 0.1s; }
  .harness-node:nth-child(5) { animation-delay: 0.15s; }
  .harness-node:nth-child(7) { animation-delay: 0.2s; }
  .harness-node:nth-child(9) { animation-delay: 0.25s; }
  .harness-node:nth-child(11) { animation-delay: 0.3s; }

  .harness-side-node:nth-child(2) { animation-delay: 0.35s; }
  .harness-side-node:nth-child(3) { animation-delay: 0.4s; }
  .harness-side-node:nth-child(4) { animation-delay: 0.45s; }

  @keyframes harnessFadeIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
